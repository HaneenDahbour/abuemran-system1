{
  "version": 2,
  "name": "abuemran-frontend",
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://YOUR-RAILWAY-APP.up.railway.app/api/$1"
    },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
