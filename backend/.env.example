# ملف البيئة - انسخه وأعد تسميته إلى .env
# لا ترفع ملف .env أبداً على GitHub!

# رابط Supabase (من: Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT Secret — اكتب أي نص عشوائي طويل هنا (مثال: حروف وأرقام عشوائية)
JWT_SECRET=replace_this_with_a_long_random_secret_string_min_32_chars

# PORT الذي سيعمل عليه السيرفر (Railway يحدده تلقائياً)
PORT=3001

# بيئة التشغيل
NODE_ENV=development
