      return apiFetch(
        `/products/import-excel?update_existing=${updateExisting ? 'true' : 'false'}`,
        { method: 'POST', body: formData }
      );
    },
    async exportProductsExcel() {
      const res = await fetch(`${API_BASE}/products/export-excel`, {
        method: 'GET',
        headers: { Authorization: `Bearer ${getToken() || ''}` },
        cache: 'no-store',
      });
      if (res.status === 401) { clearAuthAndReload(); return; }
      if (!res.ok) {
        const data = await parseResponse(res);
        throw new Error(extractErrorMessage(data, 'ЩҒШҙЩ„ ШӘШөШҜЩҠШұ Щ…Щ„ЩҒ Excel'));
      }
      const blob = await res.blob();
      let filename = 'ШӘШөШҜЩҠШұ-Ш§Щ„Щ…ШіШӘЩҲШҜШ№.xlsx';
      const disposition = res.headers.get('content-disposition') || '';
      const match = disposition.match(/filename\*=UTF-8''([^;]+)/);
      if (match?.[1]) {
        try { filename = decodeURIComponent(match[1]); } catch { filename = match[1]; }
      }
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      window.URL.revokeObjectURL(url);
    },

    // в”Җв”Җ Purchases в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
