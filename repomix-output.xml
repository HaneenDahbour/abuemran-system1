    }

    .ai-head-close:hover {
      background: rgba(255, 255, 255, .15);
      color: #fff;
    }

    .ai-analysis {
      background: linear-gradient(135deg, #eef3ff 0%, #f0fdf4 100%);
      border-bottom: 1px solid rgba(0, 0, 0, .06);
      padding: 10px 14px;
      font-size: 12px;
      line-height: 1.6;
