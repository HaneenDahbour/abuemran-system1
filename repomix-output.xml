      ${pending ? `<button class="tab-btn" id="inv-tab-pending"   onclick="setInvoiceTab('pending')"  style="color:var(--am)">вҸі Ш§ЩҶШӘШёШ§Шұ (${pending})</button>` : ''}
      <button class="tab-btn" id="inv-tab-approved" onclick="setInvoiceTab('approved')">вң… Щ…Ш№ШӘЩ…ШҜШ©</button>
      ${rejected ? `<button class="tab-btn" id="inv-tab-rejected"  onclick="setInvoiceTab('rejected')" style="color:var(--rd)">вң— Щ…ШұЩҒЩҲШ¶Ш© (${rejected})</button>` : ''}
    </div>

    <div class="card" style="padding:0;overflow:hidden">
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>ШұЩӮЩ… Ш§Щ„ЩҒШ§ШӘЩҲШұШ©</th><th>Ш§Щ„Ш№Щ…ЩҠЩ„ Ш§Щ„ШұШҰЩҠШіЩҠ</th><th>Ш§Щ„ШІШЁЩҲЩҶ</th>
              <th>Ш§Щ„ШҘШ¬Щ…Ш§Щ„ЩҠ</th><th>Ш§Щ„Щ…ШҜЩҒЩҲШ№</th><th>Ш§Щ„ШЁШ§ЩӮЩҠ</th>
