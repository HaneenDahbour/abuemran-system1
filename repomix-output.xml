                await insert_category_audit(
                    conn,
                    user,
                    "ГҳВӯГҳВ°ГҷВҒ ГҷВҒГҳВҰГҳВ© ГҷвҖҰГҳВіГҳВӘГҷЛҶГҳВҜГҳВ№",
                    f"ГҳВӯГҳВ°ГҷВҒ ГҷВҒГҳВҰГҳВ©: {category['name']} ГўвӮ¬вҖқ ГҳВӘГҷвҖҰ ГҳВҘГҷвҖһГҳВәГҳВ§ГҳВЎ ГҳВұГҳВЁГҳВ· ГҳВ§ГҷвҖһГҳВЈГҳВөГҷвҖ ГҳВ§ГҷВҒ ГҳВ§ГҷвҖһГҳВӘГҳВ§ГҳВЁГҳВ№ГҳВ© ГҳВЁГҷвҖЎГҳВ§",
                )

        return {
            "success": True,
            "message": "ГҳВӘГҷвҖҰ ГҳВӯГҳВ°ГҷВҒ ГҳВ§ГҷвҖһГҷВҒГҳВҰГҳВ© ГҷЛҶГҳВҘГҷвҖһГҳВәГҳВ§ГҳВЎ ГҳВұГҳВЁГҳВ· ГҳВ§ГҷвҖһГҳВЈГҳВөГҷвҖ ГҳВ§ГҷВҒ ГҳВ§ГҷвҖһГҳВӘГҳВ§ГҳВЁГҳВ№ГҳВ© ГҳВЁГҷвҖЎГҳВ§",
