        if user.get("role") == "client":
            rows = await pool.fetch(
                """
                SELECT ch.*, c.name AS client_name
                FROM checks ch
                JOIN clients c ON ch.client_id = c.id
                WHERE ch.client_id = $1
                ORDER BY ch.due_date ASC
                """,
                user.get("client_id"),
            )
