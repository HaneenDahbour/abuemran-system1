      window._invoiceCategoriesCache = Array.isArray(categories) ? categories : [];

      const oldItems = Array.isArray(invoice?.items) ? invoice.items : [];

      if (oldItems.length) {
        oldItems.forEach(item => addInvoiceItemRow(item));
      } else {
