// js/api.js

(function () {
  function isBrowser() {
    return typeof window !== 'undefined';
  }

  function getApiBase() {
    if (!isBrowser()) return '/api';
    if (window.ENV_API_BASE) return window.ENV_API_BASE;
    const isLocal =
      window.location.hostname === 'localhost' ||
      window.location.hostname === '127.0.0.1';
    return isLocal ? 'http://localhost:8000/api' : '/api';
  }

  const API_BASE = getApiBase();

  function getToken() {
    try { return localStorage.getItem('token'); } catch { return null; }
  }

  function normalizePath(path) {
    if (!path) return '';
    const p = path.startsWith('/') ? path : `/${path}`;
    return p.replace(/\/+$/, '') || '/';
  }

  function requireValidId(id, label = 'id') {
    const value = String(id ?? '').trim();
    if (!value || value === 'undefined' || value === 'null') {
      throw new Error(`${label} ШәЩҠШұ ШөШӯЩҠШӯ`);
    }
    return encodeURIComponent(value);
  }

  function requireId(id, label = 'id') {
    const n = Number(id);
    if (!Number.isInteger(n) || n <= 0) {
      throw new Error(`${label} ШәЩҠШұ ШөШӯЩҠШӯ`);
    }
    return n;
  }

  function clearAuthAndReload() {
    try {
      localStorage.removeItem('token');
      localStorage.removeItem('user');
    } catch { }
    if (isBrowser()) window.location.reload();
  }

  async function parseResponse(res) {
    const contentType = res.headers.get('content-type') || '';
    const isJson = contentType.includes('application/json');
    try { return isJson ? await res.json() : await res.text(); } catch { return null; }
  }

  function extractErrorMessage(data, fallback = 'ШӯШҜШ« Ш®Ш·ШЈ ШәЩҠШұ Щ…ШӘЩҲЩӮШ№') {
    if (!data) return fallback;
    if (typeof data === 'string') return data.trim() || fallback;
    if (Array.isArray(data)) return data.map(i => extractErrorMessage(i, fallback)).join(' | ');
    if (typeof data === 'object') {
      const detail = data.detail || data.message || data.error || data.details;
      if (typeof detail === 'string') return detail;
      if (Array.isArray(detail)) {
        return detail.map(err => {
          if (typeof err === 'string') return err;
          if (err?.msg) {
            const loc = Array.isArray(err.loc) ? err.loc.join('.') : '';
            return loc ? `${loc}: ${err.msg}` : err.msg;
          }
          return JSON.stringify(err);
        }).join(' | ');
      }
      if (typeof detail === 'object' && detail !== null) return JSON.stringify(detail);
      return JSON.stringify(data);
    }
    return fallback;
  }

  async function apiFetch(path, options = {}) {
    const url = `${API_BASE}${normalizePath(path)}`;
    const headers = { ...(options.headers || {}) };
    const isFormData = typeof FormData !== 'undefined' && options.body instanceof FormData;
    if (!isFormData && !headers['Content-Type']) {
      headers['Content-Type'] = 'application/json';
    }
    const token = getToken();
    if (token) headers.Authorization = `Bearer ${token}`;
    try {
      const res = await fetch(url, { ...options, headers, cache: options.cache || 'no-store' });
      if (res.status === 401) { clearAuthAndReload(); return null; }
      const data = await parseResponse(res);
      if (!res.ok) throw new Error(extractErrorMessage(data, `HTTP ${res.status}`));
      return data;
    } catch (err) {
      if (err && err.name === 'TypeError') {
        throw new Error('Щ„Ш§ ЩҠЩ…ЩғЩҶ Ш§Щ„Ш§ШӘШөШ§Щ„ ШЁШ§Щ„Ш®Ш§ШҜЩ…. ШӘШЈЩғШҜ Щ…ЩҶ ШӘШҙШәЩҠЩ„ Ш§Щ„ШіЩҠШұЩҒШұ.');
      }
      throw err;
    }
  }

  const API = {
    // в”Җв”Җ Auth в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    login: (username, password) =>
      apiFetch('/auth/login', { method: 'POST', body: JSON.stringify({ username, password }) }),
    getUsers: () => apiFetch('/auth/users'),
    createUser: data =>
      apiFetch('/auth/users', { method: 'POST', body: JSON.stringify(data) }),
    deleteUser: id =>
      apiFetch(`/auth/users/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„Щ…ШіШӘШ®ШҜЩ…')}`, { method: 'DELETE' }),

    // в”Җв”Җ Search в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    search: q => apiFetch(`/search?q=${encodeURIComponent(q)}`),

    // в”Җв”Җ Clients в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    getClients: () => apiFetch('/clients'),
    getClient: id => apiFetch(`/clients/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„Ш№Щ…ЩҠЩ„')}`),
    createClient: data =>
      apiFetch('/clients', { method: 'POST', body: JSON.stringify(data) }),
    updateClient: (id, data) =>
      apiFetch(`/clients/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„Ш№Щ…ЩҠЩ„')}`, { method: 'PUT', body: JSON.stringify(data) }),
    deleteClient: id =>
      apiFetch(`/clients/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„Ш№Щ…ЩҠЩ„')}`, { method: 'DELETE' }),
    getClientStatement: id =>
      apiFetch(`/clients/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„Ш№Щ…ЩҠЩ„')}/statement`),

    // в”Җв”Җ Invoices в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    getInvoices: () => apiFetch('/invoices'),
    createInvoice: data =>
      apiFetch('/invoices', { method: 'POST', body: JSON.stringify(data) }),
    updateInvoice: (id, data) =>
      apiFetch(`/invoices/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„ЩҒШ§ШӘЩҲШұШ©')}`, { method: 'PUT', body: JSON.stringify(data) }),
    deleteInvoice: id =>
      apiFetch(`/invoices/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„ЩҒШ§ШӘЩҲШұШ©')}`, { method: 'DELETE' }),
    approveInvoice: id =>
      apiFetch(`/invoices/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„ЩҒШ§ШӘЩҲШұШ©')}/approve`, {
        method: 'POST',
        body: JSON.stringify({}),
      }),
    rejectInvoice: (id, reason) =>
      apiFetch(`/invoices/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„ЩҒШ§ШӘЩҲШұШ©')}/reject`, {
        method: 'POST',
        body: JSON.stringify({ reason }),
      }),

    // в”Җв”Җ Payments в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    getPayments: () => apiFetch('/payments'),
    createPayment: data =>
      apiFetch('/payments', { method: 'POST', body: JSON.stringify(data) }),
    approvePayment: id =>
      apiFetch(`/payments/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„ШҜЩҒШ№Ш©')}/approve`, { method: 'POST', body: JSON.stringify({}) }),
    rejectPayment: (id, reason) =>
      apiFetch(`/payments/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„ШҜЩҒШ№Ш©')}/reject`, { method: 'POST', body: JSON.stringify({ reason }) }),
    deletePayment: id =>
      apiFetch(`/payments/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„ШҜЩҒШ№Ш©')}`, { method: 'DELETE' }),

    // в”Җв”Җ Checks в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    getChecks: () => apiFetch('/checks'),
