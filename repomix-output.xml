    /* Helpers */
    function escHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, function (char) {
        const map = {
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;'
        };
        return map[char] || char;
      });
    }

    function nl2brSafe(value) {
      return escHtml(value).replace(/\n/g, '<br>');
    }

    function fmt(value) {
      const num = Number(value || 0);
      return num.toLocaleString('en-US', {
        minimumFractionDigits: 3,
        maximumFractionDigits: 3
      });
    }

    function closeSearchInputBlur(inputEl) {
      setTimeout(() => {
        if (typeof closeSearchDropdown === 'function') {
          closeSearchDropdown();
        }
      }, 200);

      if (inputEl) {
        inputEl.style.background = 'rgba(255,255,255,.1)';
        inputEl.style.width = '260px';
      }
    }

    if (typeof window.handleGlobalSearch !== 'function') {
      window.handleGlobalSearch = function () { };
    }

    if (typeof window.closeSearchDropdown !== 'function') {
      window.closeSearchDropdown = function () {
        const dd = document.getElementById('search-dropdown');
        if (dd) dd.style.display = 'none';
      };
    }

    if (typeof window.getUser !== 'function') {
      window.getUser = function () {
        try {
          return JSON.parse(localStorage.getItem('user') || 'null');
        } catch {
          return null;
        }
      };
    }

    if (typeof window.doLogout !== 'function') {
      window.doLogout = function () {
        localStorage.removeItem('token');
        localStorage.removeItem('user');
        window.location.reload();
      };
    }

    if (typeof window.apiFetch !== 'function') {
      window.apiFetch = async function () {
        throw new Error('apiFetch غير معرّفة. تأكد من ملف js/api.js');
      };
    }

    /* ══════════════════════════════════════════════════════════
       AI AGENT — Complete Logic
    ══════════════════════════════════════════════════════════ */
    let aiOpen = false;
    let aiHistory = [];
    let aiAnalysisLoaded = false;

    const AI_CHIPS = {
      admin: ['ملخص مالي اليوم', 'أعلى العملاء ديناً', 'الشيكات المستحقة', 'مدفوعات معلّقة', 'تقرير أسبوعي'],
      accountant: ['الشيكات هذا الأسبوع', 'ملخص المقبوضات', 'عملاء بخطر عالٍ', 'إجمالي الديون'],
      employee: ['مقبوضاتي اليوم', 'الشيكات المعلّقة'],
      client: ['رصيدي الحالي', 'آخر فواتيري', 'شيكاتي المعلّقة']
    };

    function initAIChips() {
      const user = getUser();
      const chips = AI_CHIPS[user?.role] || AI_CHIPS.client;
      const container = document.getElementById('ai-chips');
      if (!container) return;

      container.innerHTML = chips.map(c =>
        `<button class="ai-chip" onclick="sendChip('${escHtml(c)}')">${escHtml(c)}</button>`
      ).join('');
    }

    function sendChip(text) {
      const input = document.getElementById('ai-input');
      if (!input) return;
      input.value = text;
      sendAIMessage();
    }

    function toggleAI() {
      aiOpen = !aiOpen;
      const panel = document.getElementById('aiPanel');
      if (!panel) return;

      panel.classList.toggle('open', aiOpen);

      if (aiOpen && !aiAnalysisLoaded) {
        loadAIAnalysis();
        aiAnalysisLoaded = true;
      }

      if (aiOpen) {
        setTimeout(() => document.getElementById('ai-input')?.focus(), 200);
      }
    }

    async function loadAIAnalysis() {
      const banner = document.getElementById('ai-analysis-banner');
      if (!banner) return;

      const user = getUser();
      if (!user || user.role === 'client') {
        banner.style.display = 'none';
        return;
      }

      try {
        const data = await apiFetch('/ai/analyze', {
          method: 'POST',
          body: JSON.stringify({})
        });

        if (data?.analysis) {
          banner.innerHTML = `
            <div class="ai-analysis-icon">✨</div>
            <div class="ai-analysis-text" style="font-size:11.5px; line-height:1.65;">${nl2brSafe(data.analysis)}</div>
          `;
        } else {
          banner.style.display = 'none';
        }
      } catch (e) {
        banner.style.display = 'none';
      }
    }

    async function sendAIMessage() {
      const input = document.getElementById('ai-input');
      const chat = document.getElementById('ai-messages');
      const sendBtn = document.getElementById('ai-send-btn');
      const statusEl = document.getElementById('ai-status-text');

      if (!input || !chat || !sendBtn) return;

      const msg = input.value.trim();
      if (!msg) return;

      const now = new Date().toLocaleTimeString('ar-JO', {
        hour: '2-digit',
        minute: '2-digit'
      });

      chat.innerHTML += `<div class="msg-user">${escHtml(msg)}<span class="msg-time">${now}</span></div>`;
      input.value = '';
      input.disabled = true;
      sendBtn.disabled = true;
      if (statusEl) statusEl.textContent = 'يكتب...';
      chat.scrollTop = chat.scrollHeight;

      const typingEl = document.createElement('div');
      typingEl.className = 'msg-typing';
      typingEl.id = 'ai-typing';
      typingEl.innerHTML = `
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      `;
      chat.appendChild(typingEl);
      chat.scrollTop = chat.scrollHeight;

      aiHistory.push({ role: 'user', content: msg });

      try {
        const res = await apiFetch('/ai/chat', {
          method: 'POST',
          body: JSON.stringify({
            message: msg,
            history: aiHistory.slice(-8)
          })
        });

        typingEl.remove();

        const reply = res?.reply || 'لم أتمكن من الإجابة';
        aiHistory.push({ role: 'assistant', content: reply });

        const replyTime = new Date().toLocaleTimeString('ar-JO', {
          hour: '2-digit',
          minute: '2-digit'
        });

        chat.innerHTML += `<div class="msg-bot">${nl2brSafe(reply)}<span class="msg-time">${replyTime}</span></div>`;
      } catch (e) {
        typingEl.remove();
        const errMsg = e?.message || 'حدث خطأ غير متوقع';
        chat.innerHTML += `<div class="msg-bot" style="color:var(--rd)">❌ ${escHtml(errMsg)}</div>`;
      }

      chat.scrollTop = chat.scrollHeight;
      input.disabled = false;
      sendBtn.disabled = false;
      input.focus();
      if (statusEl) statusEl.textContent = 'جاهز للمساعدة';
    }

    window._analyticsCache = {};

    async function renderAnalyticsTabs(containerId, period = 'weekly') {
      const container = document.getElementById(containerId);
      if (!container) return;

      container.innerHTML = `
        <div class="analytics-tabs">
          <button class="atab ${period === 'daily' ? 'active' : ''}" onclick="loadAnalytics('${containerId}','daily')">يومي</button>
          <button class="atab ${period === 'weekly' ? 'active' : ''}" onclick="loadAnalytics('${containerId}','weekly')">أسبوعي</button>
          <button class="atab ${period === 'monthly' ? 'active' : ''}" onclick="loadAnalytics('${containerId}','monthly')">شهري</button>
        </div>
        <div id="analytics-chart-${containerId}">
          <div class="loading"><div class="spinner"></div></div>
        </div>
      `;

      await loadAnalytics(containerId, period);
    }

    async function loadAnalytics(containerId, period) {
      const tabs = document.querySelectorAll(`#${containerId} .atab`);
      const labelsMap = { daily: 'يومي', weekly: 'أسبوعي', monthly: 'شهري' };
      tabs.forEach(t => {
        t.classList.toggle('active', t.textContent.trim() === labelsMap[period]);
      });

      const chartEl = document.getElementById(`analytics-chart-${containerId}`);
      if (!chartEl) return;

      chartEl.innerHTML = `<div class="loading"><div class="spinner"></div></div>`;

      try {
        const data = await apiFetch(`/ai/analytics?period=${encodeURIComponent(period)}`);
        const sales = Array.isArray(data?.sales) ? data.sales : [];

        if (!sales.length) {
          chartEl.innerHTML = `<div style="text-align:center; padding:30px; color:var(--tx3); font-size:13px">لا توجد بيانات لهذه الفترة</div>`;
          return;
        }

        const maxVal = Math.max(...sales.map(s => parseFloat(s.total_sales || 0)), 1);
        const labels = { daily: 'يوم', weekly: 'أسبوع', monthly: 'شهر' };

        const bars = sales.slice(-12).map(s => {
          const totalSales = parseFloat(s.total_sales || 0);
          const height = Math.max((totalSales / maxVal) * 100, 3);

          let dateLabel = '';
          const dt = new Date(s.period);
          if (!Number.isNaN(dt.getTime())) {
            dateLabel = dt.toLocaleDateString('ar-JO', {
              month: 'short',
              day: period === 'monthly' ? undefined : 'numeric'
            });
          } else {
            dateLabel = escHtml(String(s.period || '—'));
          }

          return `
            <div class="chart-bar-col">
              <div class="chart-bar"
                   style="height:${height}%; background: linear-gradient(180deg,#1a4fd6,#1238a8);"
                   data-val="${fmt(totalSales)} د.أ"></div>
              <div class="chart-bar-label">${dateLabel}</div>
            </div>
          `;
        }).join('');

        const totalSales = sales.reduce((sum, row) => sum + parseFloat(row.total_sales || 0), 0);
        const paymentsTotal = (Array.isArray(data?.payments) ? data.payments : [])
          .reduce((sum, row) => sum + parseFloat(row.total_collected || 0), 0);

        chartEl.innerHTML = `
          <div style="display:flex; gap:16px; margin-bottom:12px; flex-wrap:wrap">
            <div style="background:#eef3ff; border-radius:9px; padding:8px 14px; font-size:12px">
              <div style="color:#9e9a94; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.5px">المبيعات</div>
              <div style="font-size:17px; font-weight:800; color:#1a4fd6">${fmt(totalSales)} <span style="font-size:11px">د.أ</span></div>
            </div>
            <div style="background:#edfaf4; border-radius:9px; padding:8px 14px; font-size:12px">
              <div style="color:#9e9a94; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.5px">المحصّل</div>
              <div style="font-size:17px; font-weight:800; color:#0a7650">${fmt(paymentsTotal)} <span style="font-size:11px">د.أ</span></div>
            </div>
          </div>
          <div class="chart-bar-wrap">${bars}</div>
          <div style="font-size:10px; color:#9e9a94; text-align:center; margin-top:6px">المبيعات ${labels[period]}</div>
        `;
      } catch (e) {
        chartEl.innerHTML = `<div class="alert alert-danger" style="font-size:12px">تعذّر تحميل الإحصائيات</div>`;
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      const aiIn = document.getElementById('ai-input');
      if (aiIn) {
        aiIn.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendAIMessage();
          }
        });
      }

      const wt = document.getElementById('ai-welcome-time');
      if (wt) {
        wt.textContent = new Date().toLocaleTimeString('ar-JO', {
          hour: '2-digit',
          minute: '2-digit'
        });
      }

      const aiWidget = document.getElementById('ai-widget');
      const user = typeof getUser === 'function' ? getUser() : null;
      if (user && aiWidget) {
        aiWidget.style.display = 'flex';
        initAIChips();
      }
    });

    const aiObserver = new MutationObserver(() => {
      const user = typeof getUser === 'function' ? getUser() : null;
      const widget = document.getElementById('ai-widget');
      if (user && widget && widget.style.display === 'none') {
        widget.style.display = 'flex';
        initAIChips();
      }
    });

    aiObserver.observe(document.body, {
      subtree: true,
      childList: true,
      attributes: true
    });
  </script>

</body>

</html>
