      <div class="ai-msgs" id="ai-messages">
        <div class="msg-bot">
          ШЈЩҮЩ„Ш§ЩӢ! рҹ‘Ӣ ШЈЩҶШ§ Щ…ШіШ§Ш№ШҜЩғ Ш§Щ„Щ…Ш§Щ„ЩҠ Ш§Щ„Ш°ЩғЩҠ. ЩҠЩ…ЩғЩҶЩҶЩҠ ШӘШӯЩ„ЩҠЩ„ Ш§Щ„ШҜЩҠЩҲЩҶ ЩҲШ§Щ„Щ…ШЁЩҠШ№Ш§ШӘ ЩҲЩ…ШӘШ§ШЁШ№Ш© Ш§Щ„ШҙЩҠЩғШ§ШӘ. ЩғЩҠЩҒ ЩҠЩ…ЩғЩҶЩҶЩҠ Щ…ШіШ§Ш№ШҜШӘЩғШҹ
          <span class="msg-time" id="ai-welcome-time"></span>
        </div>
      </div>

      <div class="ai-input-row">
        <input class="ai-input-field" id="ai-input" placeholder="Ш§ШіШЈЩ„ЩҶЩҠ Ш№ЩҶ Ш§Щ„ШӯШіШ§ШЁШ§ШӘ..." />
        <button class="ai-send-btn" onclick="sendAIMessage()" id="ai-send-btn">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
          </svg>
        </button>
      </div>
    </div>

    <button class="ai-fab" onclick="toggleAI()" title="Ш§Щ„Щ…ШіШ§Ш№ШҜ Ш§Щ„Ш°ЩғЩҠ">
      <div class="ai-fab-pulse"></div>
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"
          fill="white" opacity=".3" />
        <circle cx="12" cy="12" r="3" fill="white" />
        <path
          d="M19.07 4.93A10 10 0 0 0 4.93 19.07M19.07 19.07A10 10 0 0 0 4.93 4.93"
          stroke="white"
          stroke-width="1.5"
          stroke-linecap="round"
          opacity=".5" />
      </svg>
    </button>
  </div>

  <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ TOAST CONTAINER в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
  <div id="toast-wrap"></div>

  <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ SCRIPTS в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
<script src="js/api.js?v=slash-fix-20260602"></script>
  <script src="js/auth.js"></script>
  <script src="js/dashboard.js"></script>
  <script src="js/search.js"></script>

  <script>
    /* Helpers */
    function escHtml(value) {
      return String(value ?? '').replace(/[&<>"']/g, function (char) {
        const map = {
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;'
        };
        return map[char] || char;
      });
    }

    function nl2brSafe(value) {
      return escHtml(value).replace(/\n/g, '<br>');
    }

    function fmt(value) {
      const num = Number(value || 0);
      return num.toLocaleString('en-US', {
        minimumFractionDigits: 3,
        maximumFractionDigits: 3
      });
    }

    function closeSearchInputBlur(inputEl) {
      setTimeout(() => {
        if (typeof closeSearchDropdown === 'function') {
          closeSearchDropdown();
        }
      }, 200);

      if (inputEl) {
        inputEl.style.background = 'rgba(255,255,255,.1)';
        inputEl.style.width = '260px';
      }
    }

    if (typeof window.handleGlobalSearch !== 'function') {
      window.handleGlobalSearch = function () { };
    }

    if (typeof window.closeSearchDropdown !== 'function') {
      window.closeSearchDropdown = function () {
        const dd = document.getElementById('search-dropdown');
        if (dd) dd.style.display = 'none';
      };
    }

    if (typeof window.getUser !== 'function') {
      window.getUser = function () {
        try {
          return JSON.parse(localStorage.getItem('user') || 'null');
        } catch {
          return null;
        }
      };
    }

    if (typeof window.doLogout !== 'function') {
      window.doLogout = function () {
        localStorage.removeItem('token');
        localStorage.removeItem('user');
        window.location.reload();
      };
    }

    if (typeof window.apiFetch !== 'function') {
      window.apiFetch = async function () {
        throw new Error('apiFetch ШәЩҠШұ Щ…Ш№ШұЩ‘ЩҒШ©. ШӘШЈЩғШҜ Щ…ЩҶ Щ…Щ„ЩҒ js/api.js');
      };
    }

    /* в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
       AI AGENT вҖ” Complete Logic
    в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ */
    let aiOpen = false;
    let aiHistory = [];
    let aiAnalysisLoaded = false;

    const AI_CHIPS = {
      admin: ['Щ…Щ„Ш®Шө Щ…Ш§Щ„ЩҠ Ш§Щ„ЩҠЩҲЩ…', 'ШЈШ№Щ„Щү Ш§Щ„Ш№Щ…Щ„Ш§ШЎ ШҜЩҠЩҶШ§ЩӢ', 'Ш§Щ„ШҙЩҠЩғШ§ШӘ Ш§Щ„Щ…ШіШӘШӯЩӮШ©', 'Щ…ШҜЩҒЩҲШ№Ш§ШӘ Щ…Ш№Щ„Щ‘ЩӮШ©', 'ШӘЩӮШұЩҠШұ ШЈШіШЁЩҲШ№ЩҠ'],
      accountant: ['Ш§Щ„ШҙЩҠЩғШ§ШӘ ЩҮШ°Ш§ Ш§Щ„ШЈШіШЁЩҲШ№', 'Щ…Щ„Ш®Шө Ш§Щ„Щ…ЩӮШЁЩҲШ¶Ш§ШӘ', 'Ш№Щ…Щ„Ш§ШЎ ШЁШ®Ш·Шұ Ш№Ш§Щ„ЩҚ', 'ШҘШ¬Щ…Ш§Щ„ЩҠ Ш§Щ„ШҜЩҠЩҲЩҶ'],
      employee: ['Щ…ЩӮШЁЩҲШ¶Ш§ШӘЩҠ Ш§Щ„ЩҠЩҲЩ…', 'Ш§Щ„ШҙЩҠЩғШ§ШӘ Ш§Щ„Щ…Ш№Щ„Щ‘ЩӮШ©'],
      client: ['ШұШөЩҠШҜЩҠ Ш§Щ„ШӯШ§Щ„ЩҠ', 'ШўШ®Шұ ЩҒЩҲШ§ШӘЩҠШұЩҠ', 'ШҙЩҠЩғШ§ШӘЩҠ Ш§Щ„Щ…Ш№Щ„Щ‘ЩӮШ©']
    };

    function initAIChips() {
      const user = getUser();
      const chips = AI_CHIPS[user?.role] || AI_CHIPS.client;
      const container = document.getElementById('ai-chips');
      if (!container) return;

      container.innerHTML = chips.map(c =>
        `<button class="ai-chip" onclick="sendChip('${escHtml(c)}')">${escHtml(c)}</button>`
      ).join('');
    }

    function sendChip(text) {
      const input = document.getElementById('ai-input');
      if (!input) return;
      input.value = text;
      sendAIMessage();
    }

    function toggleAI() {
      aiOpen = !aiOpen;
      const panel = document.getElementById('aiPanel');
      if (!panel) return;

      panel.classList.toggle('open', aiOpen);

      if (aiOpen && !aiAnalysisLoaded) {
        loadAIAnalysis();
        aiAnalysisLoaded = true;
      }

      if (aiOpen) {
        setTimeout(() => document.getElementById('ai-input')?.focus(), 200);
      }
    }

    async function loadAIAnalysis() {
      const banner = document.getElementById('ai-analysis-banner');
      if (!banner) return;

      const user = getUser();
      if (!user || user.role === 'client') {
        banner.style.display = 'none';
        return;
      }

      try {
        const data = await apiFetch('/ai/analyze', {
          method: 'POST',
          body: JSON.stringify({})
        });

        if (data?.analysis) {
          banner.innerHTML = `
            <div class="ai-analysis-icon">вңЁ</div>
            <div class="ai-analysis-text" style="font-size:11.5px; line-height:1.65;">${nl2brSafe(data.analysis)}</div>
          `;
        } else {
          banner.style.display = 'none';
        }
      } catch (e) {
        banner.style.display = 'none';
      }
    }

    async function sendAIMessage() {
      const input = document.getElementById('ai-input');
      const chat = document.getElementById('ai-messages');
      const sendBtn = document.getElementById('ai-send-btn');
      const statusEl = document.getElementById('ai-status-text');

      if (!input || !chat || !sendBtn) return;

      const msg = input.value.trim();
      if (!msg) return;

      const now = new Date().toLocaleTimeString('ar-JO', {
        hour: '2-digit',
        minute: '2-digit'
      });

      chat.innerHTML += `<div class="msg-user">${escHtml(msg)}<span class="msg-time">${now}</span></div>`;
      input.value = '';
      input.disabled = true;
      sendBtn.disabled = true;
      if (statusEl) statusEl.textContent = 'ЩҠЩғШӘШЁ...';
      chat.scrollTop = chat.scrollHeight;

      const typingEl = document.createElement('div');
      typingEl.className = 'msg-typing';
      typingEl.id = 'ai-typing';
      typingEl.innerHTML = `
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
        <div class="typing-dot"></div>
      `;
      chat.appendChild(typingEl);
      chat.scrollTop = chat.scrollHeight;

      aiHistory.push({ role: 'user', content: msg });

      try {
        const res = await apiFetch('/ai/chat', {
          method: 'POST',
          body: JSON.stringify({
            message: msg,
            history: aiHistory.slice(-8)
          })
        });

        typingEl.remove();

        const reply = res?.reply || 'Щ„Щ… ШЈШӘЩ…ЩғЩҶ Щ…ЩҶ Ш§Щ„ШҘШ¬Ш§ШЁШ©';
        aiHistory.push({ role: 'assistant', content: reply });

        const replyTime = new Date().toLocaleTimeString('ar-JO', {
          hour: '2-digit',
          minute: '2-digit'
        });

        chat.innerHTML += `<div class="msg-bot">${nl2brSafe(reply)}<span class="msg-time">${replyTime}</span></div>`;
      } catch (e) {
        typingEl.remove();
        const errMsg = e?.message || 'ШӯШҜШ« Ш®Ш·ШЈ ШәЩҠШұ Щ…ШӘЩҲЩӮШ№';
        chat.innerHTML += `<div class="msg-bot" style="color:var(--rd)">вқҢ ${escHtml(errMsg)}</div>`;
      }

      chat.scrollTop = chat.scrollHeight;
      input.disabled = false;
      sendBtn.disabled = false;
      input.focus();
      if (statusEl) statusEl.textContent = 'Ш¬Ш§ЩҮШІ Щ„Щ„Щ…ШіШ§Ш№ШҜШ©';
    }

    window._analyticsCache = {};

    async function renderAnalyticsTabs(containerId, period = 'weekly') {
      const container = document.getElementById(containerId);
      if (!container) return;

      container.innerHTML = `
        <div class="analytics-tabs">
          <button class="atab ${period === 'daily' ? 'active' : ''}" onclick="loadAnalytics('${containerId}','daily')">ЩҠЩҲЩ…ЩҠ</button>
          <button class="atab ${period === 'weekly' ? 'active' : ''}" onclick="loadAnalytics('${containerId}','weekly')">ШЈШіШЁЩҲШ№ЩҠ</button>
          <button class="atab ${period === 'monthly' ? 'active' : ''}" onclick="loadAnalytics('${containerId}','monthly')">ШҙЩҮШұЩҠ</button>
        </div>
        <div id="analytics-chart-${containerId}">
          <div class="loading"><div class="spinner"></div></div>
        </div>
      `;

      await loadAnalytics(containerId, period);
    }

    async function loadAnalytics(containerId, period) {
      const tabs = document.querySelectorAll(`#${containerId} .atab`);
      const labelsMap = { daily: 'ЩҠЩҲЩ…ЩҠ', weekly: 'ШЈШіШЁЩҲШ№ЩҠ', monthly: 'ШҙЩҮШұЩҠ' };
      tabs.forEach(t => {
        t.classList.toggle('active', t.textContent.trim() === labelsMap[period]);
      });

      const chartEl = document.getElementById(`analytics-chart-${containerId}`);
      if (!chartEl) return;

      chartEl.innerHTML = `<div class="loading"><div class="spinner"></div></div>`;

      try {
        const data = await apiFetch(`/ai/analytics?period=${encodeURIComponent(period)}`);
        const sales = Array.isArray(data?.sales) ? data.sales : [];

        if (!sales.length) {
          chartEl.innerHTML = `<div style="text-align:center; padding:30px; color:var(--tx3); font-size:13px">Щ„Ш§ ШӘЩҲШ¬ШҜ ШЁЩҠШ§ЩҶШ§ШӘ Щ„ЩҮШ°ЩҮ Ш§Щ„ЩҒШӘШұШ©</div>`;
          return;
        }

        const maxVal = Math.max(...sales.map(s => parseFloat(s.total_sales || 0)), 1);
        const labels = { daily: 'ЩҠЩҲЩ…', weekly: 'ШЈШіШЁЩҲШ№', monthly: 'ШҙЩҮШұ' };

        const bars = sales.slice(-12).map(s => {
          const totalSales = parseFloat(s.total_sales || 0);
          const height = Math.max((totalSales / maxVal) * 100, 3);

          let dateLabel = '';
          const dt = new Date(s.period);
          if (!Number.isNaN(dt.getTime())) {
            dateLabel = dt.toLocaleDateString('ar-JO', {
              month: 'short',
              day: period === 'monthly' ? undefined : 'numeric'
            });
          } else {
            dateLabel = escHtml(String(s.period || 'вҖ”'));
          }

          return `
            <div class="chart-bar-col">
              <div class="chart-bar"
                   style="height:${height}%; background: linear-gradient(180deg,#1a4fd6,#1238a8);"
                   data-val="${fmt(totalSales)} ШҜ.ШЈ"></div>
              <div class="chart-bar-label">${dateLabel}</div>
            </div>
          `;
        }).join('');

        const totalSales = sales.reduce((sum, row) => sum + parseFloat(row.total_sales || 0), 0);
        const paymentsTotal = (Array.isArray(data?.payments) ? data.payments : [])
          .reduce((sum, row) => sum + parseFloat(row.total_collected || 0), 0);

        chartEl.innerHTML = `
          <div style="display:flex; gap:16px; margin-bottom:12px; flex-wrap:wrap">
            <div style="background:#eef3ff; border-radius:9px; padding:8px 14px; font-size:12px">
              <div style="color:#9e9a94; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.5px">Ш§Щ„Щ…ШЁЩҠШ№Ш§ШӘ</div>
              <div style="font-size:17px; font-weight:800; color:#1a4fd6">${fmt(totalSales)} <span style="font-size:11px">ШҜ.ШЈ</span></div>
            </div>
            <div style="background:#edfaf4; border-radius:9px; padding:8px 14px; font-size:12px">
              <div style="color:#9e9a94; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.5px">Ш§Щ„Щ…ШӯШөЩ‘Щ„</div>
              <div style="font-size:17px; font-weight:800; color:#0a7650">${fmt(paymentsTotal)} <span style="font-size:11px">ШҜ.ШЈ</span></div>
            </div>
          </div>
          <div class="chart-bar-wrap">${bars}</div>
          <div style="font-size:10px; color:#9e9a94; text-align:center; margin-top:6px">Ш§Щ„Щ…ШЁЩҠШ№Ш§ШӘ ${labels[period]}</div>
        `;
      } catch (e) {
        chartEl.innerHTML = `<div class="alert alert-danger" style="font-size:12px">ШӘШ№Ш°Щ‘Шұ ШӘШӯЩ…ЩҠЩ„ Ш§Щ„ШҘШӯШөШ§ШҰЩҠШ§ШӘ</div>`;
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      const aiIn = document.getElementById('ai-input');
      if (aiIn) {
        aiIn.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendAIMessage();
          }
        });
      }

      const wt = document.getElementById('ai-welcome-time');
      if (wt) {
        wt.textContent = new Date().toLocaleTimeString('ar-JO', {
          hour: '2-digit',
          minute: '2-digit'
        });
      }

      const aiWidget = document.getElementById('ai-widget');
      const user = typeof getUser === 'function' ? getUser() : null;
      if (user && aiWidget) {
        aiWidget.style.display = 'flex';
        initAIChips();
      }
    });

    const aiObserver = new MutationObserver(() => {
      const user = typeof getUser === 'function' ? getUser() : null;
      const widget = document.getElementById('ai-widget');
      if (user && widget && widget.style.display === 'none') {
        widget.style.display = 'flex';
        initAIChips();
      }
    });

    aiObserver.observe(document.body, {
      subtree: true,
      childList: true,
      attributes: true
    });
  </script>

</body>

