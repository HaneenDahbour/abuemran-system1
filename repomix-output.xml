          <button class="btn btn-ghost btn-sm" onclick="printMyStatementFromEncoded(${jsString(myClient.name)}, ${jsString(encoded)})">рҹ–ЁпёҸ Ш·ШЁШ§Ш№Ш©</button>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Ш§Щ„ШӘШ§ШұЩҠШ®</th><th>Ш§Щ„ШЁЩҠШ§ЩҶ</th><th>Щ…ШҜЩҠЩҶ (Ш№Щ„ЩҠЩғ)</th><th>ШҜШ§ШҰЩҶ (Щ„Щғ)</th><th>Ш§Щ„ШұШөЩҠШҜ</th></tr></thead>
