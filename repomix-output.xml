    updateCheckStatus: (id, status) =>
      apiFetch(`/checks/${requireId(id, 'Щ…Ш№ШұЩ‘ЩҒ Ш§Щ„ШҙЩҠЩғ')}/status`, { method: 'PUT', body: JSON.stringify({ status }) }),
