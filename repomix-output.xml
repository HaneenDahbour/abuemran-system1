import os
import random
import string
from datetime import datetime, timedelta

from dotenv import load_dotenv
from fastapi import APIRouter, Depends, HTTPException
from jose import jwt
from passlib.context import CryptContext
from pydantic import BaseModel

from config.db import get_pool
from middleware.auth import get_current_user
from middleware.roles import require_role
from typing import Optional

load_dotenv()

router = APIRouter()

JWT_SECRET = os.getenv("JWT_SECRET")
ALGORITHM = "HS256"

pwd_context = CryptContext(schemes=["bcrypt"], deprecated="auto")


class LoginRequest(BaseModel):
    username: str
    password: str


class CreateUserRequest(BaseModel):
    username: str
    password: str
    full_name: str
    role: str
    client_id: Optional[int] = None
    recipient_name: Optional[str] = None


@router.post("/login")
async def login(data: LoginRequest):
    pool = await get_pool()

    if not data.username or not data.password:
        raise HTTPException(status_code=400, detail="ГҳВ§ГҳВіГҷвҖҰ ГҳВ§ГҷвҖһГҷвҖҰГҳВіГҳВӘГҳВ®ГҳВҜГҷвҖҰ ГҷЛҶГҷЖ’ГҷвҖһГҷвҖҰГҳВ© ГҳВ§ГҷвҖһГҷвҖҰГҳВұГҷЛҶГҳВұ ГҷвҖҰГҳВ·ГҷвҖһГҷЛҶГҳВЁГҳВ§ГҷвҖ ")

    user = await pool.fetchrow("SELECT * FROM users WHERE username = $1", data.username)

    if not user:
        raise HTTPException(status_code=401, detail="ГҳВЁГҷЕ ГҳВ§ГҷвҖ ГҳВ§ГҳВӘ ГҳВ§ГҷвҖһГҳВҜГҳВ®ГҷЛҶГҷвҖһ ГҳВәГҷЕ ГҳВұ ГҳВөГҳВӯГҷЕ ГҳВӯГҳВ©")

    valid = pwd_context.verify(data.password, user["password_hash"])

    if not valid:
        raise HTTPException(status_code=401, detail="ГҳВЁГҷЕ ГҳВ§ГҷвҖ ГҳВ§ГҳВӘ ГҳВ§ГҷвҖһГҳВҜГҳВ®ГҷЛҶГҷвҖһ ГҳВәГҷЕ ГҳВұ ГҳВөГҳВӯГҷЕ ГҳВӯГҳВ©")

    payload = {
        "id": user["id"],
        "username": user["username"],
        "role": user["role"],
        "full_name": user["full_name"],
        "client_id": user["client_id"],
        "recipient_name": user["recipient_name"],
        "exp": datetime.utcnow() + timedelta(days=7),
    }

    token = jwt.encode(payload, JWT_SECRET, algorithm=ALGORITHM)

    try:
        await pool.execute(
            """
            INSERT INTO audit_log (user_id, user_name, action, detail)
            VALUES ($1, $2, 'ГҳВӘГҳВіГҳВ¬ГҷЕ ГҷвҖһ ГҳВҜГҳВ®ГҷЛҶГҷвҖһ', $3)
            """,
            user["id"],
            user["full_name"],
            f"ГҳВҜГҳВ®ГҷЛҶГҷвҖһ ГҷвҖҰГҷвҖ  ГҷвҖҡГҷВҗГҳВЁГҷвҖһ {user['full_name']}",
        )
    except Exception:
        pass

    return {
        "token": token,
        "user": {
            "id": user["id"],
            "username": user["username"],
            "full_name": user["full_name"],
            "recipient_name": user["recipient_name"],
            "role": user["role"],
            "client_id": user["client_id"],
        },
    }


@router.get("/users")
async def get_users(user=Depends(get_current_user)):
    require_role(user, "admin")

    pool = await get_pool()

    rows = await pool.fetch("""
        SELECT id, username, full_name, role, client_id, recipient_name, created_at
        FROM users
        ORDER BY created_at DESC
        """)

    return [dict(row) for row in rows]


@router.post("/users")
async def create_user(data: CreateUserRequest, user=Depends(get_current_user)):
    require_role(user, "admin")

    valid_roles = ["admin", "accountant", "employee", "client", "recipient"]

    if data.role not in valid_roles:
        raise HTTPException(status_code=400, detail="ГҳВ§ГҷвҖһГҳВөГҷвҖһГҳВ§ГҳВӯГҷЕ ГҳВ© ГҳВ§ГҷвҖһГҷвҖҰГҳВӯГҳВҜГҳВҜГҳВ© ГҳВәГҷЕ ГҳВұ ГҳВөГҳВ§ГҷвҖһГҳВӯГҳВ©")

    if data.role == "client" and not data.client_id:
        raise HTTPException(
            status_code=400, detail="ГҳВӯГҳВіГҳВ§ГҳВЁ ГҳВ§ГҷвҖһГҳВ№ГҷвҖҰГҷЕ ГҷвҖһ ГҷЕ ГҳВӯГҳВӘГҳВ§ГҳВ¬ ГҳВұГҳВЁГҳВ·ГҷвҖЎ ГҳВЁГҳВ№ГҷвҖҰГҷЕ ГҷвҖһ ГҳВұГҳВҰГҷЕ ГҳВіГҷЕ "
        )

    if data.role == "recipient" and not data.recipient_name:
        raise HTTPException(
            status_code=400, detail="ГҳВӯГҳВіГҳВ§ГҳВЁ ГҳВ§ГҷвҖһГҳВІГҳВЁГҷЛҶГҷвҖ  ГҷЕ ГҳВӯГҳВӘГҳВ§ГҳВ¬ ГҳВ§ГҳВіГҷвҖҰ ГҳВ§ГҷвҖһГҳВІГҳВЁГҷЛҶГҷвҖ  ГҷЖ’ГҷвҖҰГҳВ§ ГҷЕ ГҳВёГҷвҖЎГҳВұ ГҷВҒГҷЕ  ГҳВ§ГҷвҖһГҷВҒГҷЛҶГҳВ§ГҳВӘГҷЕ ГҳВұ"
        )

    pool = await get_pool()

    existing = await pool.fetchrow(
        "SELECT id FROM users WHERE username = $1", data.username
    )

    if existing:
        raise HTTPException(status_code=409, detail="ГҳВ§ГҳВіГҷвҖҰ ГҳВ§ГҷвҖһГҷвҖҰГҳВіГҳВӘГҳВ®ГҳВҜГҷвҖҰ ГҷвҖҰГҳВӯГҳВ¬ГҷЛҶГҳВІ ГҳВЁГҳВ§ГҷвҖһГҷВҒГҳВ№ГҷвҖһ")

    hashed_password = pwd_context.hash(data.password)

    new_user = await pool.fetchrow(
        """
        INSERT INTO users (username, password_hash, full_name, role, client_id, recipient_name)
        VALUES ($1, $2, $3, $4, $5, $6)
        RETURNING id, username, full_name, role, client_id, recipient_name
        """,
        data.username,
        hashed_password,
        data.full_name,
        data.role,
        data.client_id,
        data.recipient_name.strip() if data.recipient_name else None,
    )

    try:
        await pool.execute(
            """
            INSERT INTO audit_log (user_id, user_name, action, detail)
            VALUES ($1, $2, 'ГҳВҘГҷвҖ ГҳВҙГҳВ§ГҳВЎ ГҷвҖҰГҳВіГҳВӘГҳВ®ГҳВҜГҷвҖҰ', $3)
            """,
            user["id"],
            user["full_name"],
            f"ГҳВҘГҷвҖ ГҳВҙГҳВ§ГҳВЎ ГҷвҖҰГҳВіГҳВӘГҳВ®ГҳВҜГҷвҖҰ ГҳВ¬ГҳВҜГҷЕ ГҳВҜ: {data.username} ({data.role})",
        )
    except Exception:
        pass

    return dict(new_user)


@router.delete("/users/{user_id}")
async def delete_user(user_id: int, user=Depends(get_current_user)):
    require_role(user, "admin")

    if int(user_id) == int(user["id"]):
        raise HTTPException(status_code=400, detail="ГҷвҖһГҳВ§ ГҷЕ ГҷвҖҰГҷЖ’ГҷвҖ ГҷЖ’ ГҳВӯГҳВ°ГҷВҒ ГҳВӯГҳВіГҳВ§ГҳВЁГҷЖ’ ГҳВ§ГҷвҖһГҳВ®ГҳВ§ГҳВө")

    pool = await get_pool()

    deleted = await pool.fetchrow(
        "DELETE FROM users WHERE id = $1 RETURNING username", user_id
    )

    if not deleted:
        raise HTTPException(status_code=404, detail="ГҳВ§ГҷвҖһГҷвҖҰГҳВіГҳВӘГҳВ®ГҳВҜГҷвҖҰ ГҳВәГҷЕ ГҳВұ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ")

    try:
        await pool.execute(
            """
            INSERT INTO audit_log (user_id, user_name, action, detail)
            VALUES ($1, $2, 'ГҳВӯГҳВ°ГҷВҒ ГҷвҖҰГҳВіГҳВӘГҳВ®ГҳВҜГҷвҖҰ', $3)
            """,
            user["id"],
            user["full_name"],
            f"ГҳВӯГҳВ°ГҷВҒ ГҷвҖҰГҳВіГҳВӘГҳВ®ГҳВҜГҷвҖҰ: {deleted['username']}",
        )
    except Exception:
        pass

    return {"success": True}


@router.get("/telegram-code")
async def telegram_code(user=Depends(get_current_user)):
    pool = await get_pool()

    code = "".join(random.choices(string.ascii_uppercase + string.digits, k=8))

    await pool.execute(
        "UPDATE users SET telegram_link_code = $1 WHERE id = $2", code, user["id"]
    )

    return {"code": code}
