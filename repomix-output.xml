function setProductButtonLoading(btn, loading, text = 'Ш¬Ш§ШұЩҠ Ш§Щ„ШӯЩҒШё...') {
  if (!btn) return;

  if (loading) {
    btn.dataset.oldText = btn.textContent;
    btn.disabled = true;
    btn.style.opacity = '0.65';
    btn.style.pointerEvents = 'none';
    btn.textContent = text;
  } else {
    btn.disabled = false;
    btn.style.opacity = '1';
    btn.style.pointerEvents = '';
    btn.textContent = btn.dataset.oldText || 'ШӯЩҒШё';
  }
}

