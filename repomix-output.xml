                )

                if duplicate:
                    raise HTTPException(
                        status_code=400, detail="ГҳВ№ГҷвҖҰГҷЕ ГҷвҖһ ГҳВЁГҷвҖЎГҳВ°ГҳВ§ ГҳВ§ГҷвҖһГҳВ§ГҳВіГҷвҖҰ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ ГҷвҖҰГҳВіГҳВЁГҷвҖҡГҳВ§ГҷвҖ№"
                    )

                row = await conn.fetchrow(
                    """
                    INSERT INTO clients (name, department, credit_limit, risk_level, phone)
                    VALUES ($1, $2, $3, $4, $5)
                    RETURNING *
