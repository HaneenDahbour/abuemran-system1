  <style>
    /* ══ AI AGENT — Complete Redesign ══════════════════════════════ */
    .ai-widget {
      position: fixed;
      bottom: 28px;
      left: 28px;
      z-index: 400;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }

    .ai-fab {
      width: 56px;
      height: 56px;
      background: linear-gradient(135deg, #1a1815 0%, #2d2a26 100%);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 4px 24px rgba(0, 0, 0, .35), 0 0 0 1px rgba(255, 255, 255, .07);
      border: none;
      position: relative;
      transition: transform .2s, box-shadow .2s;
      align-self: flex-start;
      margin-top: 8px;
    }

    .ai-fab:hover {
      transform: scale(1.06);
      box-shadow: 0 6px 30px rgba(0, 0, 0, .4);
    }

    .ai-fab svg {
      width: 24px;
      height: 24px;
    }

    .ai-fab-pulse {
      position: absolute;
      top: -3px;
      right: -3px;
      width: 13px;
      height: 13px;
      background: #22c55e;
      border-radius: 50%;
      border: 2px solid #f0ede8;
      animation: aipulse 2.5s infinite;
    }

    @keyframes aipulse {

      0%,
      100% {
        transform: scale(1);
        opacity: 1;
      }

      50% {
        transform: scale(1.25);
        opacity: .6;
      }
    }

    .ai-panel {
      position: absolute;
      bottom: 68px;
      left: 0;
      width: 370px;
      height: 520px;
      background: #ffffff;
      border: 1px solid rgba(0, 0, 0, .1);
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, .18), 0 0 0 1px rgba(0, 0, 0, .04);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      direction: rtl;
      opacity: 0;
      transform: translateY(12px) scale(.96);
      pointer-events: none;
      transition: opacity .22s ease, transform .22s ease;
    }

    .ai-panel.open {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: all;
    }

    .ai-head {
