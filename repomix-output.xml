function productMiniDetails(p) {
  const props = parseProductProperties(p);
  const category = String(p.category_name || p.category || '').trim();

  const parts = [];

  if (props.brand_or_type) parts.push(`Ш§Щ„ЩҶЩҲШ№: ${props.brand_or_type}`);
  if (props.model) parts.push(`Ш§Щ„Щ…ЩҲШҜЩҠЩ„: ${props.model}`);
  if (props.color) parts.push(`Ш§Щ„Щ„ЩҲЩҶ: ${props.color}`);
  if (props.size) parts.push(`Ш§Щ„Щ…ЩӮШ§Ші: ${props.size}`);

  if (props.containers_count) {
    if (category.includes('Ш§Щ„Ш§ШҜЩҲШ§ШӘ') || category.includes('Щ…ЩҶШІЩ„')) {
      parts.push(`Ш№ШҜШҜ Ш§Щ„ЩғШұШ§ШӘЩҠЩҶ: ${props.containers_count}`);
    } else {
      parts.push(`Ш№ШҜШҜ Ш§Щ„ШҙЩҲШ§Щ„Ш§ШӘ: ${props.containers_count}`);
    }
  }

  if (props.pack_size) parts.push(`Ш§Щ„ШӘШ№ШЁШҰШ©: ${props.pack_size}`);
  if (props.loose_count) parts.push(`ШҘЩҒШұШ§ШҜЩҠ: ${props.loose_count}`);
  if (props.original_total_qty) parts.push(`Ш§Щ„ЩғЩ„ЩҠ: ${props.original_total_qty}`);

  if (!parts.length) return '';

  return `
    <div class="product-mini-details">
      ${parts.map(x => `<span>${escHtml(x)}</span>`).join('')}
    </div>
  `;
}

function productNameWithDetails(p) {
  return `
    <div class="product-name-cell">
      <div class="product-main-name">${escHtml(p.name || '')}</div>
      ${productMiniDetails(p)}
    </div>
  `;
}
