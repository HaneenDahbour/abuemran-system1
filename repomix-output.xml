│   ├── seed.js                 # بيانات تجريبية — يُشغَّل مرة واحدة
│   ├── .env                    # المتغيرات السرية — لا تُرفع على GitHub
│   ├── config/
│   │   └── db.js               # اتصال PostgreSQL عبر pg Pool
│   ├── middleware/
│   │   ├── auth.js             # التحقق من JWT Token
