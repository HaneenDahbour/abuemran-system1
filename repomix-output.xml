  }
}

/* ── RISK LEVELS ──────────────────────────────────────── */
.risk-low {
  color: var(--gr);
}

.risk-medium {
  color: var(--am);
}

.risk-high {
  color: var(--rd);
}

/* ── SECTION TABS ─────────────────────────────────────── */
.tabs {
  display: flex;
  gap: 4px;
  background: var(--bg);
  border: 1px solid var(--brd);
  border-radius: var(--r);
  padding: 4px;
  margin-bottom: 20px;
  width: fit-content;
}

.tab-btn {
  padding: 7px 16px;
  border-radius: 7px;
  border: none;
  background: transparent;
  font-family: inherit;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  color: var(--tx2);
  transition: .15s;
}

.tab-btn.active {
  background: var(--sur2);
  color: var(--tx);
  font-weight: 700;
  box-shadow: var(--shadow);
}

/* ── PRINT ────────────────────────────────────────────── */
@media print {

  .sidebar,
  .topbar,
  .ai-widget {
    display: none !important;
  }

  .main {
    padding: 0;
  }
}

/* ── AI WIDGET ────────────────────────────────────────── */
.ai-widget {
  position: fixed;
  bottom: 28px;
  left: 28px;
  z-index: 400;
}

.ai-btn {
  width: 52px;
  height: 52px;
  background: var(--ink);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 4px 20px rgba(0, 0, 0, .3);
  font-size: 22px;
  border: 2px solid rgba(255, 255, 255, .1);
  transition: .2s;
}

.ai-btn:hover {
  transform: scale(1.05);
}

.ai-panel {
  position: absolute;
  bottom: 64px;
  left: 0;
  width: 340px;
  height: 460px;
  background: var(--sur2);
  border: 1px solid var(--brdm);
  border-radius: 18px;
  box-shadow: var(--shadow-lg);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  direction: rtl;
}

.ai-header {
  background: var(--ink);
  color: white;
  padding: 14px 16px;
  font-weight: 700;
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.ai-messages {
  flex: 1;
  overflow-y: auto;
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.msg-bot,
.msg-user {
  padding: 9px 13px;
  border-radius: 10px;
  font-size: 13px;
  max-width: 85%;
  line-height: 1.5;
}

.msg-bot {
  background: var(--bg);
  align-self: flex-start;
  border-radius: 10px 10px 10px 2px;
}

.msg-user {
  background: var(--bl);
  color: white;
  align-self: flex-end;
  border-radius: 10px 10px 2px 10px;
}

.ai-input {
  display: flex;
  gap: 8px;
  padding: 10px;
  border-top: 1px solid var(--brd);
}

.ai-input input {
  flex: 1;
  padding: 9px 12px;
  border: 1px solid var(--brdm);
  border-radius: 8px;
  font-family: inherit;
  font-size: 13px;
  outline: none;
  direction: rtl;
  text-align: right;
}

/* ── ACCOUNT STATEMENT ────────────────────────────────── */
.statement-header {
  background: var(--ink);
  color: white;
  padding: 28px 32px;
  border-radius: var(--rl) var(--rl) 0 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.balance-hero {
  font-size: 38px;
  font-weight: 800;
  letter-spacing: -2px;
  margin-top: 6px;
}

/* ── RESPONSIVE ───────────────────────────────────────── */
@media (max-width: 768px) {
  .app-layout {
    grid-template-columns: 1fr;
  }

  .sidebar {
    display: none;
  }

  .form-row {
    grid-template-columns: 1fr;
  }

  .metrics-grid {
    grid-template-columns: 1fr 1fr;
  }
}

.msg-bot {
  background: var(--bg);
  align-self: flex-start;
  border-radius: 10px 10px 10px 2px;
  max-width: 90%;
  /* Don't let it hit the edges */
  word-wrap: break-word;
  /* Ensure long links don't break the UI */
}
</file>

