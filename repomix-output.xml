  window._invoicesCache = invoices || [];

  const pending = (invoices || []).filter(i => (i.status || 'approved') === 'pending').length;
  const rejected = (invoices || []).filter(i => (i.status || 'approved') === 'rejected').length;

  container.innerHTML = `
