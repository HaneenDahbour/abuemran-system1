      <input class="form-input" id="nu_name" placeholder="Щ…Ш«Ш§Щ„: ШЈШӯЩ…ШҜ Щ…ШӯЩ…ШҜ">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Ш§ШіЩ… Ш§Щ„Щ…ШіШӘШ®ШҜЩ… *</label>
        <input class="form-input" id="nu_user" placeholder="ШЁШ§Щ„ШҘЩҶШ¬Щ„ЩҠШІЩҠШ©">
      </div>
      <div class="form-group">
        <label class="form-label">ЩғЩ„Щ…Ш© Ш§Щ„Щ…ШұЩҲШұ *</label>
        <input class="form-input" id="nu_pass" type="password" placeholder="вҖўвҖўвҖўвҖўвҖўвҖў">
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Ш§Щ„ШөЩ„Ш§ШӯЩҠШ© *</label>
      <select class="form-select" id="nu_role">
        <option value="accountant">Щ…ШӯШ§ШіШЁ</option>
        <option value="employee">Щ…ЩҲШёЩҒ</option>
        <option value="admin">Щ…ШҜЩҠШұ Ш№Ш§Щ…</option>
        <option value="client">Ш№Щ…ЩҠЩ„</option>
      </select>
    </div>
    <div style="display:flex; gap:10px; margin-top:8px">
      <button class="btn btn-primary" style="flex:1" onclick="saveUser()">ШҘЩҶШҙШ§ШЎ Ш§Щ„ШӯШіШ§ШЁ</button>
      <button class="btn btn-ghost" onclick="closeModal()">ШҘЩ„ШәШ§ШЎ</button>
    </div>
  `);
}

async function saveUser() {
  const name = document.getElementById('nu_name').value.trim();
  const username = document.getElementById('nu_user').value.trim();
  const password = document.getElementById('nu_pass').value;
  const role = document.getElementById('nu_role').value;

  if (!name || !username || !password) {
    toast('ЩҠШұШ¬Щү Щ…Щ„ШЎ Ш¬Щ…ЩҠШ№ Ш§Щ„ШӯЩӮЩҲЩ„', 'error');
    return;
  }

  try {
    await API.createUser({ full_name: name, username, password, role });
    toast('ШӘЩ… ШҘЩҶШҙШ§ШЎ Ш§Щ„ШӯШіШ§ШЁ ШЁЩҶШ¬Ш§Шӯ', 'success');
    closeModal();
    navigateTo('users');
  } catch (e) {
    toast(e.message, 'error');
  }
}

async function deleteUser(id, name) {
  if (!confirm(`ШӯШ°ЩҒ Ш§Щ„Щ…ШіШӘШ®ШҜЩ… "${name}"Шҹ`)) return;
  try {
    await API.deleteUser(id);
    toast('ШӘЩ… ШӯШ°ЩҒ Ш§Щ„Щ…ШіШӘШ®ШҜЩ…', 'success');
    navigateTo('users');
  } catch (e) {
    toast(e.message, 'error');
  }
}

