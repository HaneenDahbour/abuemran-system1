                      }
                    </td>

                    <td style="font-weight:700">${fmt(total)} د.أ</td>

                    <td style="color:var(--gr); font-weight:700">${fmt(paid)} د.أ</td>

                    <td style="color:${remaining > 0 ? 'var(--rd)' : 'var(--gr)'}; font-weight:700">
                      ${fmt(remaining)} د.أ
