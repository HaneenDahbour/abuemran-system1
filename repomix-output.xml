    border:1px solid #eee;
    padding:8px 10px;
    border-radius:10px;
  `;

  row.innerHTML = `
    <select
      class="form-select"
      id="ii_cat_${idx}"
      onchange="handleInvoiceItemCategoryChange(${idx})"
    >
      <option value="">Ш§Ш®ШӘШұ Ш§Щ„ЩҒШҰШ©</option>
      ${invoiceCategoryOptionsHtml(selectedCategoryId)}
    </select>

    <select
      class="form-select"
      id="ii_prod_${idx}"
      onchange="handleInvoiceProductChange(${idx})"
      ${selectedCategoryId ? '' : 'disabled'}
    >
      ${invoiceProductOptionsHtml(selectedCategoryId, selectedProductId)}
    </select>

    <input
      class="form-input"
      id="ii_desc_${idx}"
      value="${escHtml(description)}"
      placeholder="Ш§Щ„ШЁЩҠШ§ЩҶ / Ш§Щ„ЩҲШөЩҒ"
      style="font-weight:600"
      oninput="this.dataset.manual='1'"
    >

    <input
      class="form-input"
      id="ii_qty_${idx}"
      type="number"
      value="${qty ? qty.toFixed(3) : ''}"
      placeholder="Ш§Щ„ЩғЩ…ЩҠШ©"
      min="0"
      step="0.001"
      oninput="calcInvoiceLineAuto(${idx})"
    >

    <input
      class="form-input"
      id="ii_pack_qty_${idx}"
      type="number"
      value="${packQty ? packQty.toFixed(0) : '12'}"
      placeholder="12"
      min="1"
      step="1"
      title="Ш№ШҜШҜ Ш§Щ„ШӯШЁШ§ШӘ ЩҒЩҠ Ш§Щ„ШҜШІЩҠЩҶШ© ШЈЩҲ Ш§Щ„ЩғШұШӘЩҲЩҶШ©"
      oninput="calcInvoiceLineAuto(${idx})"
    >

    <input
      class="form-input"
      id="ii_pack_price_${idx}"
      type="number"
      value="${packPrice ? packPrice.toFixed(3) : ''}"
      placeholder="ШіШ№Шұ 12"
      min="0"
      step="0.001"
      title="Щ…Ш«Щ„Ш§ЩӢ: 12 ШӯШЁШ© = 13 ШҜЩҠЩҶШ§Шұ"
      oninput="calcInvoiceLineFromPack(${idx})"
      style="font-weight:800;color:#9a4500"
    >

    <input
      class="form-input"
      id="ii_price_${idx}"
      type="number"
      value="${unit ? unit.toFixed(3) : ''}"
      placeholder="ШіШ№Шұ Ш§Щ„ШӯШЁШ©"
      min="0"
      step="0.001"
      oninput="calcInvoiceLineFromUnit(${idx})"
    >

    <input
      class="form-input"
      id="ii_total_${idx}"
