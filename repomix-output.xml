  const cat = (window._whCategoriesCache || []).find(c => String(c.id) === String(catId));
  const catName = cat?.name || '';
  const catIcon = cat?.icon || 'рҹ“Ұ';

  let products = [];

  try {
    const allProducts = await API.getProducts() || [];

