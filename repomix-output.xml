                    )

                for item in items:
                    product = await conn.fetchrow(
                        "SELECT id, name, current_stock FROM products WHERE id=$1 FOR UPDATE",
                        item["product_id"],
                    )

                    if not product:
                        raise HTTPException(
                            status_code=400,
                            detail=f"ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҳВұГҷвҖҡГҷвҖҰ {item['product_id']} ГҳВәГҷЕ ГҳВұ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ",
                        )

                    quantity = float(item["quantity"] or 0)

