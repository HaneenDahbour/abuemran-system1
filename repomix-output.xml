    html += navItem('payments', '💰', 'المقبوضات');
    html += navItem('checks', '🏦', 'الشيكات');
    html += navItem('purchases', '🛒', 'المشتريات');
  }

  if (canManageWarehouse()) {
    html += '<div class="nav-section-title">المستودع</div>';
