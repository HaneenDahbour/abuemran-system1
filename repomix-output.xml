@router.get("/{product_id}")
async def get_product(product_id: UUID, user=Depends(get_current_user)):
    pool = await get_pool()

    try:
        row = await pool.fetchrow(
            """
            SELECT p.*, wc.name AS category_name, wc.icon AS category_icon
            FROM products p
            LEFT JOIN warehouse_categories wc ON wc.id = p.category_id
            WHERE p.id=$1
            """,
            product_id,
        )

        if not row:
            raise HTTPException(status_code=404, detail="ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҳВәГҷЕ ГҳВұ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ")

        return row_to_dict(row)

    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@router.put("/{product_id}")
async def update_product(
    product_id: UUID, data: ProductRequest, user=Depends(get_current_user)
):
    require_warehouse_editor(user)

    name = clean_text(data.name)
    sku = clean_text(data.sku)
    unit = clean_text(data.unit) or "ГҷвҖҡГҳВ·ГҳВ№ГҳВ©"
    min_stock = float(data.min_stock or 0)
    category_id = int(data.category_id) if data.category_id else None

    if not name:
        raise HTTPException(status_code=400, detail="ГҳВ§ГҳВіГҷвҖҰ ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҷвҖҰГҳВ·ГҷвҖһГҷЛҶГҳВЁ")

    if min_stock < 0:
        raise HTTPException(
            status_code=400, detail="ГҳВ§ГҷвҖһГҳВӯГҳВҜ ГҳВ§ГҷвҖһГҳВЈГҳВҜГҷвҖ ГҷвҖ° ГҷвҖһГҳВ§ ГҷЕ ГҷвҖҰГҷЖ’ГҷвҖ  ГҳВЈГҷвҖ  ГҷЕ ГҷЖ’ГҷЛҶГҷвҖ  ГҳВіГҳВ§ГҷвҖһГҳВЁГҳВ§ГҷвҖ№"
        )

    if data.final_stock is not None and float(data.final_stock) < 0:
        raise HTTPException(
            status_code=400, detail="ГҳВ§ГҷвҖһГҷЖ’ГҷвҖҰГҷЕ ГҳВ© ГҳВ§ГҷвҖһГҳВӯГҳВ§ГҷвҖһГҷЕ ГҳВ© ГҷвҖһГҳВ§ ГҷЕ ГҷвҖҰГҷЖ’ГҷвҖ  ГҳВЈГҷвҖ  ГҳВӘГҷЖ’ГҷЛҶГҷвҖ  ГҳВіГҳВ§ГҷвҖһГҳВЁГҳВ©"
        )

    pool = await get_pool()

    try:
        async with pool.acquire() as conn:
            async with conn.transaction():
                current = await conn.fetchrow(
                    """
                    SELECT id, name, current_stock, properties
                    FROM products
                    WHERE id=$1
                    FOR UPDATE
                    """,
                    product_id,
                )

                if not current:
                    raise HTTPException(status_code=404, detail="ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҳВәГҷЕ ГҳВұ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ")

                await ensure_category_exists(conn, category_id)
                await ensure_sku_unique(conn, sku, exclude_product_id=product_id)

                category_name = None

                if category_id:
                    category_name = await conn.fetchval(
                        "SELECT name FROM warehouse_categories WHERE id=$1",
                        category_id,
                    )

                duplicate = await conn.fetchrow(
                    """
                    SELECT id, name
                    FROM products
                    WHERE LOWER(name) = LOWER($1)
                      AND COALESCE(category_id, 0) = COALESCE($2::int, 0)
                      AND id <> $3
                    LIMIT 1
                    """,
                    name,
                    category_id,
                    product_id,
                )

                if duplicate:
                    raise HTTPException(
                        status_code=409,
                        detail=f"ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ ГҷвҖҰГҳВіГҳВЁГҷвҖҡГҳВ§ГҷвҖ№ ГҷВҒГҷЕ  ГҷвҖЎГҳВ°ГҷвҖЎ ГҳВ§ГҷвҖһГҷВҒГҳВҰГҳВ©: {duplicate['name']}",
                    )

                old_properties = parse_product_properties(current["properties"])
                new_properties = data.properties or {}
                merged_properties = {
                    **old_properties,
                    **new_properties,
                }
                props_json = json.dumps(merged_properties, ensure_ascii=False)

                row = await conn.fetchrow(
                    """
                    UPDATE products
                    SET name=$1,
                        sku=$2,
                        category_id=$3,
                        category=$4,
                        unit=$5,
                        min_stock=$6,
                        properties=$7::jsonb
                    WHERE id=$8
                    RETURNING *
                    """,
                    name,
                    sku,
                    category_id,
                    category_name,
                    unit,
                    min_stock,
                    props_json,
                    product_id,
                )

                if data.final_stock is not None:
                    old_stock = float(current["current_stock"] or 0)
                    final_stock = float(data.final_stock)
                    diff = final_stock - old_stock

                    if diff != 0:
                        row = await conn.fetchrow(
                            """
                            UPDATE products
                            SET current_stock=$1
                            WHERE id=$2
                            RETURNING *
                            """,
                            final_stock,
                            product_id,
                        )

                        await conn.execute(
                            """
                            INSERT INTO stock_movements
                              (product_id, type, quantity, source_type, notes, created_by)
                            VALUES
                              ($1, $2, $3, 'final_stock_edit', $4, $5)
                            """,
                            product_id,
                            "in" if diff > 0 else "out",
                            abs(diff),
                            f"ГҳВӘГҳВ№ГҳВҜГҷЕ ГҷвҖһ ГҳВ§ГҷвҖһГҷЖ’ГҷвҖҰГҷЕ ГҳВ© ГҷвҖҰГҷвҖ  {old_stock} ГҳВҘГҷвҖһГҷвҖ° {final_stock}",
                            safe_uuid(user.get("id")),
                        )

                        await insert_audit(
                            conn,
                            user,
                            "ГҳВӘГҳВ№ГҳВҜГҷЕ ГҷвҖһ ГҷЖ’ГҷвҖҰГҷЕ ГҳВ© ГҳВөГҷвҖ ГҷВҒ",
                            f"{name}: ГҷвҖҰГҷвҖ  {old_stock} ГҳВҘГҷвҖһГҷвҖ° {final_stock}",
                        )

                await insert_audit(
                    conn,
                    user,
                    "ГҳВӘГҳВ№ГҳВҜГҷЕ ГҷвҖһ ГҳВЁГҷЕ ГҳВ§ГҷвҖ ГҳВ§ГҳВӘ ГҳВөГҷвҖ ГҷВҒ",
                    f"{name}",
                )

                return row_to_dict(row)

    except HTTPException:
        raise
    except Exception as e:
        import traceback

        traceback.print_exc()
        raise HTTPException(status_code=500, detail=str(e))


@router.post("/{product_id}/adjust")
async def adjust_stock(
    product_id: UUID, data: AdjustRequest, user=Depends(get_current_user)
):
    require_warehouse_editor(user)

    qty = float(data.quantity)

    if qty == 0:
        raise HTTPException(status_code=400, detail="ГҳВ§ГҷвҖһГҷЖ’ГҷвҖҰГҷЕ ГҳВ© ГҷЕ ГҳВ¬ГҳВЁ ГҳВЈГҷвҖ  ГҳВӘГҷЖ’ГҷЛҶГҷвҖ  ГҳВұГҷвҖҡГҷвҖҰГҳВ§ГҷвҖ№ ГҳВәГҷЕ ГҳВұ ГҳВөГҷВҒГҳВұ")

    pool = await get_pool()

    try:
        async with pool.acquire() as conn:
            async with conn.transaction():
                current = await conn.fetchrow(
                    """
                    SELECT id, name, current_stock
                    FROM products
                    WHERE id=$1
                    FOR UPDATE
                    """,
                    product_id,
                )

                if not current:
                    raise HTTPException(status_code=404, detail="ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҳВәГҷЕ ГҳВұ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ")

                old_stock = float(current["current_stock"] or 0)
                new_stock = old_stock + qty

                if new_stock < 0:
                    raise HTTPException(
                        status_code=400,
                        detail=f"ГҷвҖһГҳВ§ ГҷЕ ГҷвҖҰГҷЖ’ГҷвҖ  ГҳВ®ГҳВөГҷвҖҰ {abs(qty)} ГўвӮ¬вҖқ ГҳВ§ГҷвҖһГҷвҖҰГҳВ®ГҳВІГҷЛҶГҷвҖ  ГҳВ§ГҷвҖһГҳВӯГҳВ§ГҷвҖһГҷЕ  {old_stock}",
                    )

                updated = await conn.fetchrow(
                    """
                    UPDATE products
                    SET current_stock=$1
                    WHERE id=$2
                    RETURNING *
                    """,
                    new_stock,
                    product_id,
                )

                await conn.execute(
                    """
                    INSERT INTO stock_movements
                      (product_id, type, quantity, source_type, notes, created_by)
                    VALUES
                      ($1, $2, $3, 'manual', $4, $5)
                    """,
                    product_id,
                    "in" if qty > 0 else "out",
                    abs(qty),
                    data.notes or "ГҳВӘГҳВ№ГҳВҜГҷЕ ГҷвҖһ ГҷЕ ГҳВҜГҷЛҶГҷЕ ",
                    safe_uuid(user.get("id")),
                )

                await insert_audit(
                    conn,
                    user,
                    "ГҳВӘГҳВ№ГҳВҜГҷЕ ГҷвҖһ ГҷвҖҰГҳВ®ГҳВІГҷЛҶГҷвҖ ",
                    f"{current['name']}: ГҷвҖҰГҷвҖ  {old_stock} ГҳВҘГҷвҖһГҷвҖ° {new_stock}",
                )

                return row_to_dict(updated)

    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@router.get("/{product_id}/movements")
async def get_movements(product_id: UUID, user=Depends(get_current_user)):
    pool = await get_pool()

    try:
        rows = await pool.fetch(
            """
            SELECT sm.*, u.full_name AS user_name
            FROM stock_movements sm
            LEFT JOIN users u ON u.id = sm.created_by
            WHERE sm.product_id = $1
            ORDER BY sm.created_at DESC
            LIMIT 100
            """,
            product_id,
        )

        return [row_to_dict(r) for r in rows]

    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@router.delete("/{product_id}")
async def delete_product(product_id: UUID, user=Depends(get_current_user)):
    require_role(user, "admin")

    pool = await get_pool()

    try:
        async with pool.acquire() as conn:
            async with conn.transaction():
                product = await conn.fetchrow(
                    """
                    SELECT id, name
                    FROM products
                    WHERE id = $1
                    FOR UPDATE
                    """,
                    product_id,
                )

                if not product:
                    raise HTTPException(
                        status_code=404,
                        detail="ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҳВәГҷЕ ГҳВұ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ ГҳВЈГҷЛҶ ГҳВӘГҷвҖҰ ГҳВӯГҳВ°ГҷВҒГҷвҖЎ ГҷвҖҰГҳВіГҳВЁГҷвҖҡГҳВ§ГҷвҖ№",
                    )

                used_in_invoice = await conn.fetchval(
                    "SELECT EXISTS(SELECT 1 FROM invoice_items WHERE product_id = $1)",
                    product_id,
                )

                used_in_warehouse_invoice = await conn.fetchval(
                    "SELECT EXISTS(SELECT 1 FROM warehouse_invoice_items WHERE product_id = $1)",
                    product_id,
                )

                used_in_purchase = await conn.fetchval(
                    "SELECT EXISTS(SELECT 1 FROM purchase_items WHERE product_id = $1)",
                    product_id,
                )

                if used_in_invoice or used_in_warehouse_invoice or used_in_purchase:
                    raise HTTPException(
                        status_code=409,
                        detail="ГҷвҖһГҳВ§ ГҷЕ ГҷвҖҰГҷЖ’ГҷвҖ  ГҳВӯГҳВ°ГҷВҒ ГҷвҖЎГҳВ°ГҳВ§ ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҷвҖһГҳВЈГҷвҖ ГҷвҖЎ ГҷвҖҰГҳВіГҳВӘГҳВ®ГҳВҜГҷвҖҰ ГҷВҒГҷЕ  ГҷВҒГҷЛҶГҳВ§ГҳВӘГҷЕ ГҳВұ ГҳВЈГҷЛҶ ГҷвҖҰГҳВҙГҳВӘГҳВұГҷЕ ГҳВ§ГҳВӘ. ГҳВӯГҳВӘГҷвҖ° ГҷвҖ ГҳВӯГҳВ§ГҷВҒГҳВё ГҳВ№ГҷвҖһГҷвҖ° ГҳВӘГҳВ§ГҳВұГҷЕ ГҳВ® ГҳВ§ГҷвҖһГҷВҒГҷЛҶГҳВ§ГҳВӘГҷЕ ГҳВұГҳЕ’ ГҳВ№ГҳВҜГҷвҖҳГҷвҖһГҷЕ  ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҳВЈГҷЛҶ ГҳВ§ГҳВ¬ГҳВ№ГҷвҖһГҷЕ  ГҷЖ’ГҷвҖҰГҷЕ ГҳВӘГҷвҖЎ ГҳВөГҷВҒГҳВұ ГҳВЁГҳВҜГҷвҖһ ГҳВ§ГҷвҖһГҳВӯГҳВ°ГҷВҒ.",
                    )

                await conn.execute(
                    "DELETE FROM stock_movements WHERE product_id = $1",
                    product_id,
                )

                await conn.execute(
                    "DELETE FROM products WHERE id = $1",
                    product_id,
                )

                await insert_audit(
                    conn,
                    user,
                    "ГҳВӯГҳВ°ГҷВҒ ГҳВөГҷвҖ ГҷВҒ ГҷвҖҰГҳВіГҳВӘГҷЛҶГҳВҜГҳВ№",
                    f"ГҳВӯГҳВ°ГҷВҒ ГҳВөГҷвҖ ГҷВҒ: {product['name']}",
                )

        return {
            "success": True,
            "message": "ГҳВӘГҷвҖҰ ГҳВӯГҳВ°ГҷВҒ ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҷвҖҰГҷвҖ  ГҷвҖҡГҳВ§ГҳВ№ГҳВҜГҳВ© ГҳВ§ГҷвҖһГҳВЁГҷЕ ГҳВ§ГҷвҖ ГҳВ§ГҳВӘ ГҳВЁГҷвҖ ГҳВ¬ГҳВ§ГҳВӯ",
            "deleted_id": str(product_id),
        }

    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))
