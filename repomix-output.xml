    if min_stock < 0:
        raise HTTPException(
            status_code=400, detail="ГҳВ§ГҷвҖһГҳВӯГҳВҜ ГҳВ§ГҷвҖһГҳВЈГҳВҜГҷвҖ ГҷвҖ° ГҷвҖһГҳВ§ ГҷЕ ГҷвҖҰГҷЖ’ГҷвҖ  ГҳВЈГҷвҖ  ГҷЕ ГҷЖ’ГҷЛҶГҷвҖ  ГҳВіГҳВ§ГҷвҖһГҳВЁГҳВ§ГҷвҖ№"
        )

    if opening_quantity < 0:
        raise HTTPException(
            status_code=400, detail="ГҳВ§ГҷвҖһГҷЖ’ГҷвҖҰГҷЕ ГҳВ© ГҳВ§ГҷвҖһГҳВӯГҳВ§ГҷвҖһГҷЕ ГҳВ© ГҷвҖһГҳВ§ ГҷЕ ГҷвҖҰГҷЖ’ГҷвҖ  ГҳВЈГҷвҖ  ГҳВӘГҷЖ’ГҷЛҶГҷвҖ  ГҳВіГҳВ§ГҷвҖһГҳВЁГҳВ©"
        )

    pool = await get_pool()

    try:
        async with pool.acquire() as conn:
            async with conn.transaction():
                await ensure_category_exists(conn, category_id)
                await ensure_sku_unique(conn, sku)

                category_name = None

                if category_id:
                    category_name = await conn.fetchval(
                        "SELECT name FROM warehouse_categories WHERE id=$1",
                        category_id,
                    )

                duplicate = await conn.fetchrow(
                    """
                    SELECT id, name
                    FROM products
                    WHERE LOWER(name) = LOWER($1)
                      AND COALESCE(category_id, 0) = COALESCE($2::int, 0)
                    LIMIT 1
                    """,
                    name,
                    category_id,
                )

                if duplicate:
                    raise HTTPException(
                        status_code=409,
                        detail=f"ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ ГҷвҖҰГҳВіГҳВЁГҷвҖҡГҳВ§ГҷвҖ№ ГҷВҒГҷЕ  ГҷвҖЎГҳВ°ГҷвҖЎ ГҳВ§ГҷвҖһГҷВҒГҳВҰГҳВ©: {duplicate['name']}",
                    )

                props_json = json.dumps(data.properties or {}, ensure_ascii=False)

                row = await conn.fetchrow(
                    """
                    INSERT INTO products
                      (name, sku, category_id, category, unit, min_stock, current_stock, properties)
                    VALUES
                      ($1, $2, $3, $4, $5, $6, $7, $8::jsonb)
                    RETURNING *
                    """,
                    name,
                    sku,
                    category_id,
                    category_name,
                    unit,
                    min_stock,
                    opening_quantity,
                    props_json,
                )

                if opening_quantity > 0:
                    await conn.execute(
                        """
                        INSERT INTO stock_movements
                          (product_id, type, quantity, source_type, notes, created_by)
                        VALUES
                          ($1, $2, $3, 'opening', $4, $5)
                        """,
                        row["id"],
                        "in",
                        opening_quantity,
                        f"ГҷЖ’ГҷвҖҰГҷЕ ГҳВ© ГҳВ§ГҷВҒГҳВӘГҳВӘГҳВ§ГҳВӯГҷЕ ГҳВ©: {opening_quantity} {unit}",
                        safe_uuid(user.get("id")),
                    )

                await insert_audit(
                    conn,
                    user,
                    "ГҳВЈГҳВ¶ГҳВ§ГҷВҒ ГҳВөГҷвҖ ГҷВҒ ГҷвҖҰГҳВіГҳВӘГҷЛҶГҳВҜГҳВ№",
                    f"{name} ГўвӮ¬вҖқ ГҳВ§ГҷвҖһГҷЖ’ГҷвҖҰГҷЕ ГҳВ© ГҳВ§ГҷвҖһГҳВ§ГҷВҒГҳВӘГҳВӘГҳВ§ГҳВӯГҷЕ ГҳВ©: {opening_quantity} {unit}",
                )

                return row_to_dict(row)

    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e))


@router.post("/import-excel")
async def import_products_excel(
    file: UploadFile = File(...),
    update_existing: bool = False,
    user=Depends(get_current_user),
):
    require_warehouse_editor(user)

    if not file.filename:
        raise HTTPException(status_code=400, detail="ГҳВ§ГҳВіГҷвҖҰ ГҳВ§ГҷвҖһГҷвҖҰГҷвҖһГҷВҒ ГҳВәГҷЕ ГҳВұ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ")

    if not file.filename.lower().endswith(".xlsx"):
        raise HTTPException(
            status_code=400, detail="ГҳВ§ГҷвҖһГҳВұГҳВ¬ГҳВ§ГҳВЎ ГҳВұГҷВҒГҳВ№ ГҷвҖҰГҷвҖһГҷВҒ Excel ГҳВЁГҳВөГҷЕ ГҳВәГҳВ© xlsx ГҷВҒГҷвҖҡГҳВ·"
        )

    content = await file.read()

    if not content:
        raise HTTPException(status_code=400, detail="ГҷвҖҰГҷвҖһГҷВҒ ГҳВ§ГҷвҖһГҳВҘГҷЖ’ГҳВіГҷвҖһ ГҷВҒГҳВ§ГҳВұГҳВә")

    try:
        workbook = load_workbook(BytesIO(content), data_only=True)
    except Exception:
        raise HTTPException(status_code=400, detail="ГҷвҖҰГҷвҖһГҷВҒ ГҳВ§ГҷвҖһГҳВҘГҷЖ’ГҳВіГҷвҖһ ГҳВәГҷЕ ГҳВұ ГҳВөГҳВ§ГҷвҖһГҳВӯ")

    if "import_ready_products" not in workbook.sheetnames:
        raise HTTPException(
            status_code=400,
            detail="ГҳВ§ГҳВұГҷВҒГҳВ№ ГҳВ§ГҷвҖһГҷвҖҰГҷвҖһГҷВҒ ГҳВ§ГҷвҖһГҳВ¬ГҳВ§ГҷвҖЎГҳВІ ГҷвҖһГҷвҖһГҳВ§ГҳВіГҳВӘГҷЕ ГҳВұГҳВ§ГҳВҜ ГҳВ§ГҷвҖһГҳВ°ГҷЕ  ГҷЕ ГҳВӯГҳВӘГҷЛҶГҷЕ  ГҳВ№ГҷвҖһГҷвҖ° ГҳВөГҷВҒГҳВӯГҳВ© import_ready_products",
        )

    sheet = workbook["import_ready_products"]

    if sheet.max_row < 2:
        raise HTTPException(
            status_code=400, detail="ГҷвҖҰГҷвҖһГҷВҒ ГҳВ§ГҷвҖһГҳВҘГҷЖ’ГҳВіГҷвҖһ ГҷвҖһГҳВ§ ГҷЕ ГҳВӯГҳВӘГҷЛҶГҷЕ  ГҳВ№ГҷвҖһГҷвҖ° ГҳВЈГҳВөГҷвҖ ГҳВ§ГҷВҒ ГҷвҖһГҷвҖһГҳВ§ГҳВіГҳВӘГҷЕ ГҳВұГҳВ§ГҳВҜ"
        )

    headers = [excel_text(cell.value) for cell in sheet[1]]

    required_columns = ["category", "product_name", "current_stock_qty"]

    for col in required_columns:
        if col not in headers:
            raise HTTPException(
                status_code=400,
                detail=f"ГҳВ§ГҷвҖһГҳВ№ГҷвҖҰГҷЛҶГҳВҜ ГҳВ§ГҷвҖһГҷвҖҰГҳВ·ГҷвҖһГҷЛҶГҳВЁ ГҳВәГҷЕ ГҳВұ ГҷвҖҰГҷЛҶГҳВ¬ГҷЛҶГҳВҜ ГҷВҒГҷЕ  ГҳВ§ГҷвҖһГҳВҘГҷЖ’ГҳВіГҷвҖһ: {col}",
            )

    inserted = 0
    updated = 0
    skipped = 0
    failed = []

    pool = await get_pool()

    try:
        async with pool.acquire() as conn:
            for row_index, row in enumerate(
                sheet.iter_rows(min_row=2, values_only=True), start=2
            ):
                try:
                    item = clean_excel_row(headers, row)

                    category_name = excel_text(item.get("category"))
                    product_name = build_import_product_name(item)
                    current_stock = to_float_or_zero(item.get("current_stock_qty"))

                    if not category_name or not product_name:
                        skipped += 1
                        failed.append(
                            {
                                "row": row_index,
                                "reason": "ГҳВ§ГҷвҖһГҷВҒГҳВҰГҳВ© ГҳВЈГҷЛҶ ГҳВ§ГҳВіГҷвҖҰ ГҳВ§ГҷвҖһГҳВөГҷвҖ ГҷВҒ ГҷвҖҰГҷВҒГҷвҖҡГҷЛҶГҳВҜ",
                            }
                        )
                        continue

                    if current_stock < 0:
                        skipped += 1
                        failed.append(
                            {
                                "row": row_index,
                                "product": product_name,
                                "reason": "ГҷЖ’ГҷвҖҰГҷЕ ГҳВ© ГҳВ§ГҷвҖһГҷвҖҰГҳВ®ГҳВІГҷЛҶГҷвҖ  ГҳВіГҳВ§ГҷвҖһГҳВЁГҳВ©",
                            }
                        )
                        continue

                    properties = {
                        "import_source": "excel",
                        "category_from_excel": category_name,
                        "base_product_name": excel_text(item.get("product_name")),
                        "brand_or_type": excel_text(item.get("brand_or_type")),
                        "model": excel_text(item.get("model")),
                        "color": excel_text(item.get("color")),
                        "size": excel_text(item.get("size")),
                        "pack_size": excel_json_value(item.get("pack_size")),
                        "containers_count": excel_json_value(
                            item.get("containers_count")
                        ),
                        "loose_count": excel_json_value(item.get("loose_count")),
                        "original_total_qty": excel_json_value(
                            item.get("original_total_qty")
                        ),
                        "sold_qty_before_system": excel_json_value(
                            item.get("sold_qty")
                        ),
                        "current_stock_qty_imported": current_stock,
                        "unit_price_from_excel": excel_json_value(
                            item.get("unit_price")
                        ),
                        "total_price_from_excel": excel_json_value(
                            item.get("total_price")
                        ),
                        "import_note": excel_text(item.get("import_note")),
                    }

                    props_json = json.dumps(properties, ensure_ascii=False)

                    async with conn.transaction():
                        category_id = await get_or_create_warehouse_category(
                            conn, category_name
                        )

                        existing = await conn.fetchrow(
                            """
                            SELECT id, name, current_stock
                            FROM products
                            WHERE LOWER(name) = LOWER($1)
                              AND COALESCE(category_id, 0) = COALESCE($2::int, 0)
                            LIMIT 1
                            """,
                            product_name,
                            category_id,
                        )

                        if existing:
                            if update_existing:
                                old_stock = float(existing["current_stock"] or 0)
                                diff = current_stock - old_stock

                                await conn.execute(
                                    """
                                    UPDATE products
                                    SET current_stock=$1,
                                        category=$2,
                                        properties=$3::jsonb
                                    WHERE id=$4
                                    """,
                                    current_stock,
                                    category_name,
                                    props_json,
                                    existing["id"],
                                )

                                if diff != 0:
                                    await conn.execute(
                                        """
                                        INSERT INTO stock_movements
                                          (product_id, type, quantity, source_type, notes, created_by)
                                        VALUES
                                          ($1, $2, $3, 'excel_import_update', $4, $5)
                                        """,
                                        existing["id"],
                                        "in" if diff > 0 else "out",
                                        abs(diff),
                                        f"ГҳВӘГҳВӯГҳВҜГҷЕ ГҳВ« ГҷвҖҰГҷвҖ  Excel: ГҷвҖҰГҷвҖ  {old_stock} ГҳВҘГҷвҖһГҷвҖ° {current_stock}",
                                        safe_uuid(user.get("id")),
                                    )

                                updated += 1
                            else:
                                skipped += 1

                            continue

                        created = await conn.fetchrow(
                            """
                            INSERT INTO products
                              (name, sku, category_id, category, unit, min_stock, current_stock, properties)
                            VALUES
                              ($1, NULL, $2, $3, $4, $5, $6, $7::jsonb)
                            RETURNING id
                            """,
                            product_name,
                            category_id,
                            category_name,
                            "ГҷвҖҡГҳВ·ГҳВ№ГҳВ©",
                            0,
                            current_stock,
                            props_json,
                        )

                        if current_stock > 0:
                            await conn.execute(
                                """
                                INSERT INTO stock_movements
                                  (product_id, type, quantity, source_type, notes, created_by)
                                VALUES
                                  ($1, 'in', $2, 'excel_import', $3, $4)
                                """,
                                created["id"],
                                current_stock,
                                f"ГҳВ§ГҳВіГҳВӘГҷЕ ГҳВұГҳВ§ГҳВҜ Excel ГўвӮ¬вҖқ ГҷвҖҰГҳВ®ГҳВІГҷЛҶГҷвҖ  ГҳВ§ГҷВҒГҳВӘГҳВӘГҳВ§ГҳВӯГҷЕ : {current_stock}",
                                safe_uuid(user.get("id")),
                            )

                        inserted += 1

                except Exception as row_error:
                    skipped += 1
                    failed.append(
                        {
                            "row": row_index,
                            "reason": str(row_error),
                        }
                    )
                    continue

            # ГўЕ“вҖҰ ГҷвҖҰГҷвҖЎГҷвҖҰ: ГҳВіГҳВ¬ГҷвҖһ ГҳВ§ГҷвҖһГҳВӘГҳВҜГҷвҖҡГҷЕ ГҷвҖҡ ГҳВҜГҳВ§ГҳВ®ГҷвҖһ ГҷвҖ ГҷВҒГҳВі block ГҳВӘГҳВЁГҳВ№ conn
            try:
                await insert_audit(
                    conn,
                    user,
                    "ГҳВ§ГҳВіГҳВӘГҷЕ ГҳВұГҳВ§ГҳВҜ ГҳВЈГҳВөГҷвҖ ГҳВ§ГҷВҒ ГҷвҖҰГҷвҖ  Excel",
                    f"ГҳВӘГҷвҖҰГҳВӘ ГҳВҘГҳВ¶ГҳВ§ГҷВҒГҳВ© {inserted} ГҳВөГҷвҖ ГҷВҒГҳЕ’ ГҳВӘГҳВӯГҳВҜГҷЕ ГҳВ« {updated} ГҳВөГҷвҖ ГҷВҒГҳЕ’ ГҳВӘГҳВ®ГҳВ·ГҷЕ  {skipped} ГҳВөГҷвҖ ГҷВҒ",
                )
            except Exception as audit_error:
                print("Audit log failed after Excel import:", audit_error)

        return {
            "success": True,
            "inserted": inserted,
            "updated": updated,
            "skipped": skipped,
            "failed": failed[:50],
            "message": f"ГҳВӘГҷвҖҰ ГҳВ§ГҷвҖһГҳВ§ГҳВіГҳВӘГҷЕ ГҳВұГҳВ§ГҳВҜ: ГҳВҘГҳВ¶ГҳВ§ГҷВҒГҳВ© {inserted}ГҳЕ’ ГҳВӘГҳВӯГҳВҜГҷЕ ГҳВ« {updated}ГҳЕ’ ГҳВӘГҳВ®ГҳВ·ГҷЕ  {skipped}",
        }

    except HTTPException:
        raise
    except Exception as e:
        import traceback

        traceback.print_exc()
        raise HTTPException(status_code=500, detail=str(e))


