<file path="frontend/css/style.css">
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700;800&display=swap');

:root {
  --bg: #f0ede8;
  --sur: #faf9f7;
  --sur2: #ffffff;
  --brd: rgba(0, 0, 0, .07);
  --brdm: rgba(0, 0, 0, .13);
  --tx: #1a1815;
  --tx2: #5a5650;
  --tx3: #9e9a94;
  --bl: #1a4fd6;
  --bll: #eef3ff;
  --bld: #1238a8;
  --gr: #0a7650;
  --grl: #edfaf4;
  --am: #9a4500;
  --aml: #fff8ee;
  --rd: #c21515;
  --rdl: #fff0f0;
  --ink: #1a1815;
  --r: 10px;
  --rl: 14px;
  --shadow: 0 2px 8px rgba(0, 0, 0, .07), 0 0 0 1px rgba(0, 0, 0, .04);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, .12), 0 0 0 1px rgba(0, 0, 0, .05);
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: 'IBM Plex Sans Arabic', system-ui, sans-serif;
  background: var(--bg);
  color: var(--tx);
  min-height: 100vh;
  font-size: 14px;
  line-height: 1.6;
}

.hidden {
  display: none !important;
}

/* в”Җв”Җ LOGIN в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.login-page {
  min-height: 100vh;
  display: grid;
  place-items: center;
  background: var(--bg);
  background-image: radial-gradient(ellipse at 20% 80%, rgba(26, 79, 214, .08) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 20%, rgba(10, 118, 80, .06) 0%, transparent 60%);
  padding: 1rem;
}

.login-card {
  background: var(--sur2);
  border: 1px solid var(--brdm);
  border-radius: 20px;
  padding: 48px 44px;
  width: 100%;
  max-width: 420px;
  box-shadow: var(--shadow-lg);
}

.login-logo {
  width: 64px;
  height: 64px;
  background: var(--ink);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  margin: 0 auto 24px;
}

.login-title {
  text-align: center;
  font-size: 22px;
  font-weight: 800;
  letter-spacing: -.5px;
  margin-bottom: 6px;
}

.login-sub {
  text-align: center;
  color: var(--tx3);
  font-size: 13px;
  margin-bottom: 36px;
}

/* в”Җв”Җ APP LAYOUT в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.app-layout {
  display: grid;
  grid-template-columns: 240px 1fr;
  grid-template-rows: 56px 1fr;
  min-height: 100vh;
}

/* в”Җв”Җ TOPBAR в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.topbar {
  grid-column: 1 / -1;
  background: var(--ink);
  color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 1.5rem;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2px solid rgba(255, 255, 255, .06);
}

.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 15px;
  font-weight: 800;
  letter-spacing: -.3px;
}

.brand-dot {
  width: 8px;
  height: 8px;
  background: #22c55e;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {

  0%,
  100% {
    opacity: 1;
    transform: scale(1);
  }

  50% {
    opacity: .6;
    transform: scale(.85);
  }
}

.top-right {
  display: flex;
  align-items: center;
  gap: 12px;
}

.user-pill {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(255, 255, 255, .1);
  border: 1px solid rgba(255, 255, 255, .12);
  border-radius: 100px;
  padding: 5px 14px 5px 8px;
  cursor: default;
}

.user-avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: var(--bl);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  color: white;
}

.user-name {
  font-size: 13px;
  font-weight: 600;
}

.user-role {
  font-size: 10px;
  opacity: .6;
}

.btn-logout {
  background: rgba(255, 255, 255, .08);
  border: 1px solid rgba(255, 255, 255, .12);
  border-radius: var(--r);
  padding: 6px 14px;
  color: rgba(255, 255, 255, .8);
  font-family: inherit;
  font-size: 12px;
  cursor: pointer;
  transition: .2s;
}

.btn-logout:hover {
  background: rgba(255, 255, 255, .14);
  color: white;
}

/* в”Җв”Җ SIDEBAR в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.sidebar {
  background: var(--sur2);
  border-left: 1px solid var(--brd);
  padding: 20px 12px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  position: sticky;
  top: 56px;
  height: calc(100vh - 56px);
  overflow-y: auto;
}

.nav-section-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.2px;
  color: var(--tx3);
  padding: 8px 12px 4px;
  margin-top: 8px;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  border-radius: var(--r);
  cursor: pointer;
  color: var(--tx2);
  font-size: 13px;
  font-weight: 500;
  transition: .15s;
  position: relative;
  user-select: none;
}

.nav-item:hover {
  background: var(--bg);
  color: var(--tx);
}

.nav-item.active {
  background: var(--bll);
  color: var(--bl);
  font-weight: 700;
}

.nav-item.active::before {
  content: '';
  position: absolute;
  right: 0;
  top: 4px;
  bottom: 4px;
  width: 3px;
  background: var(--bl);
  border-radius: 3px 0 0 3px;
}

.nav-icon {
  width: 20px;
  text-align: center;
  font-size: 15px;
}

.nav-badge {
  margin-right: auto;
  background: var(--rd);
  color: white;
  font-size: 10px;
  font-weight: 700;
  padding: 1px 6px;
  border-radius: 20px;
}

/* в”Җв”Җ MAIN CONTENT в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.main {
  padding: 24px;
  overflow-y: auto;
  background: var(--bg);
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}

.page-title {
  font-size: 22px;
  font-weight: 800;
  letter-spacing: -.5px;
}

.page-sub {
  font-size: 13px;
  color: var(--tx3);
  margin-top: 2px;
}

/* в”Җв”Җ CARDS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.card {
  background: var(--sur2);
  border: 1px solid var(--brd);
  border-radius: var(--rl);
  padding: 24px;
  box-shadow: var(--shadow);
}

.card-title {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.product-name-cell {
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.product-main-name {
  font-weight: 700;
  color: #111827;
}

.product-mini-details {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  font-size: 11px;
  color: #374151;
}

.product-mini-details span {
  background: #f3f4f6;
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 3px 7px;
  white-space: nowrap;
}
/* в”Җв”Җ METRICS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
  margin-bottom: 20px;
}

.metric-card {
  background: var(--sur2);
  border: 1px solid var(--brd);
  border-radius: var(--rl);
  padding: 20px 22px;
  box-shadow: var(--shadow);
  position: relative;
  overflow: hidden;
}

.metric-card::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 4px;
  bottom: 0;
  border-radius: 0 var(--rl) var(--rl) 0;
}

.metric-card.blue::after {
  background: var(--bl);
}

.metric-card.green::after {
  background: var(--gr);
}

.metric-card.amber::after {
  background: var(--am);
}

.metric-card.red::after {
  background: var(--rd);
}

.metric-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--tx3);
  text-transform: uppercase;
  letter-spacing: .8px;
  margin-bottom: 8px;
}

.metric-value {
  font-size: 26px;
  font-weight: 800;
  letter-spacing: -1px;
}

.metric-sub {
  font-size: 11px;
  color: var(--tx3);
  margin-top: 4px;
}

.metric-icon {
  font-size: 22px;
  position: absolute;
  top: 18px;
  left: 20px;
  opacity: .15;
}

/* в”Җв”Җ TABLES в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.table-wrap {
  overflow-x: auto;
  border-radius: var(--rl);
  border: 1px solid var(--brd);
}

table {
  width: 100%;
  border-collapse: collapse;
}

thead th {
  background: #f5f3f0;
  padding: 11px 16px;
  text-align: right;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .6px;
  color: var(--tx3);
  white-space: nowrap;
}

tbody tr {
  border-top: 1px solid var(--brd);
  transition: background .12s;
}

tbody tr:hover {
  background: #faf9f7;
}

td {
  padding: 14px 16px;
  font-size: 13px;
}

td strong {
  font-weight: 700;
}

/* в”Җв”Җ BADGES в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 3px 9px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 700;
}

.badge-blue {
  background: var(--bll);
  color: var(--bld);
}

.badge-green {
  background: var(--grl);
  color: var(--gr);
}

.badge-amber {
  background: var(--aml);
  color: var(--am);
}

.badge-red {
  background: var(--rdl);
  color: var(--rd);
}

.badge-gray {
  background: #f0ede8;
  color: var(--tx2);
}

/* в”Җв”Җ BUTTONS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 9px 16px;
  border-radius: var(--r);
  border: none;
  font-family: inherit;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  transition: .15s;
  white-space: nowrap;
}

.btn-primary {
  background: var(--bl);
  color: white;
}

.btn-primary:hover {
  background: var(--bld);
}

.btn-success {
  background: var(--gr);
  color: white;
}

.btn-success:hover {
  background: #085f3f;
}

.btn-danger {
  background: var(--rd);
  color: white;
}

.btn-danger:hover {
  background: #a01010;
}

.btn-ghost {
  background: transparent;
  border: 1px solid var(--brdm);
  color: var(--tx2);
}

.btn-ghost:hover {
  background: var(--bg);
}

.btn-sm {
  padding: 6px 12px;
  font-size: 12px;
}

.btn-full {
  width: 100%;
}

.btn-lg {
  padding: 13px 20px;
  font-size: 14px;
}

/* в”Җв”Җ FORMS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.form-group {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 12px;
  font-weight: 700;
  color: var(--tx2);
  margin-bottom: 6px;
  text-align: right;
}

.form-input,
.form-select {
  width: 100%;
  padding: 10px 14px;
  border: 1px solid var(--brdm);
  border-radius: var(--r);
  background: var(--sur2);
  color: var(--tx);
  font-family: inherit;
  font-size: 13px;
  outline: none;
  transition: .15s;
  text-align: right;
  direction: rtl;
}

.form-input:focus,
.form-select:focus {
  border-color: var(--bl);
  box-shadow: 0 0 0 3px rgba(26, 79, 214, .1);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

/* в”Җв”Җ MODAL в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.modal-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, .45);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 500;
  padding: 16px;
  animation: fadeIn .15s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

.modal {
  background: var(--sur2);
  border-radius: 18px;
  padding: 28px;
  width: 100%;
  max-width: 500px;
  max-height: 90vh;
  overflow-y: auto;
  box-shadow: var(--shadow-lg);
  animation: slideUp .2s ease;
  direction: rtl;
}

@keyframes slideUp {
  from {
    transform: translateY(16px);
    opacity: 0;
  }

  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}

.modal-title {
  font-size: 17px;
  font-weight: 800;
}

.modal-close {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  border: 1px solid var(--brdm);
  background: transparent;
  cursor: pointer;
  font-size: 16px;
  color: var(--tx2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: inherit;
}

/* в”Җв”Җ SEARCH BAR в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.search-bar {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--sur2);
  border: 1px solid var(--brdm);
  border-radius: var(--r);
  padding: 8px 14px;
  flex: 1;
  max-width: 320px;
}

.search-bar input {
  flex: 1;
  border: none;
  outline: none;
  font-family: inherit;
  font-size: 13px;
  background: transparent;
  text-align: right;
  direction: rtl;
}

/* в”Җв”Җ ALERTS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.alert {
  padding: 12px 16px;
  border-radius: var(--r);
  font-size: 13px;
  font-weight: 500;
  border-right: 3px solid;
  margin-bottom: 12px;
}

.alert-info {
  background: var(--bll);
  color: var(--bld);
  border-color: var(--bl);
}

.alert-success {
  background: var(--grl);
  color: var(--gr);
  border-color: var(--gr);
}

.alert-warning {
  background: var(--aml);
  color: var(--am);
  border-color: var(--am);
}

.alert-danger {
  background: var(--rdl);
  color: var(--rd);
  border-color: var(--rd);
}

/* в”Җв”Җ EMPTY STATE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: var(--tx3);
}

.empty-state .empty-icon {
  font-size: 40px;
  margin-bottom: 12px;
}

.empty-state p {
  font-size: 14px;
}

/* в”Җв”Җ LOADING в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.loading {
  text-align: center;
  padding: 40px;
  color: var(--tx3);
}

.spinner {
  width: 28px;
  height: 28px;
  border: 3px solid var(--brd);
  border-top-color: var(--bl);
  border-radius: 50%;
  animation: spin .7s linear infinite;
  margin: 0 auto 12px;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* в”Җв”Җ TOAST в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
#toast-wrap {
  position: fixed;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  gap: 8px;
  pointer-events: none;
}

.toast {
  padding: 12px 20px;
  border-radius: var(--r);
  font-size: 13px;
  font-weight: 600;
  color: white;
  animation: toastIn .2s ease;
  pointer-events: all;
  box-shadow: 0 4px 16px rgba(0, 0, 0, .15);
}

.toast-success {
  background: var(--gr);
}

.toast-error {
  background: var(--rd);
}

.toast-info {
  background: var(--bl);
}

@keyframes toastIn {
  from {
    transform: translateY(10px);
    opacity: 0;
  }

  to {
    transform: translateY(0);
    opacity: 1;
  }
}

/* в”Җв”Җ RISK LEVELS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.risk-low {
  color: var(--gr);
}

.risk-medium {
  color: var(--am);
}

.risk-high {
  color: var(--rd);
}

/* в”Җв”Җ SECTION TABS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.tabs {
  display: flex;
  gap: 4px;
  background: var(--bg);
  border: 1px solid var(--brd);
  border-radius: var(--r);
  padding: 4px;
  margin-bottom: 20px;
  width: fit-content;
}

.tab-btn {
  padding: 7px 16px;
  border-radius: 7px;
  border: none;
  background: transparent;
  font-family: inherit;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  color: var(--tx2);
  transition: .15s;
}

.tab-btn.active {
  background: var(--sur2);
  color: var(--tx);
  font-weight: 700;
  box-shadow: var(--shadow);
}

/* в”Җв”Җ PRINT в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
@media print {

  .sidebar,
  .topbar,
  .ai-widget {
    display: none !important;
  }

  .main {
    padding: 0;
  }
}

/* в”Җв”Җ AI WIDGET в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.ai-widget {
  position: fixed;
  bottom: 28px;
  left: 28px;
  z-index: 400;
}

.ai-btn {
  width: 52px;
  height: 52px;
  background: var(--ink);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 4px 20px rgba(0, 0, 0, .3);
  font-size: 22px;
  border: 2px solid rgba(255, 255, 255, .1);
  transition: .2s;
}

.ai-btn:hover {
  transform: scale(1.05);
}

.ai-panel {
  position: absolute;
  bottom: 64px;
  left: 0;
  width: 340px;
  height: 460px;
  background: var(--sur2);
  border: 1px solid var(--brdm);
  border-radius: 18px;
  box-shadow: var(--shadow-lg);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  direction: rtl;
}

.ai-header {
  background: var(--ink);
  color: white;
  padding: 14px 16px;
  font-weight: 700;
  font-size: 13px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.ai-messages {
  flex: 1;
  overflow-y: auto;
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.msg-bot,
.msg-user {
  padding: 9px 13px;
  border-radius: 10px;
  font-size: 13px;
  max-width: 85%;
  line-height: 1.5;
}

.msg-bot {
  background: var(--bg);
  align-self: flex-start;
  border-radius: 10px 10px 10px 2px;
}

.msg-user {
  background: var(--bl);
  color: white;
  align-self: flex-end;
  border-radius: 10px 10px 2px 10px;
}

.ai-input {
  display: flex;
  gap: 8px;
  padding: 10px;
  border-top: 1px solid var(--brd);
}

.ai-input input {
  flex: 1;
  padding: 9px 12px;
  border: 1px solid var(--brdm);
  border-radius: 8px;
  font-family: inherit;
  font-size: 13px;
  outline: none;
  direction: rtl;
  text-align: right;
}

/* в”Җв”Җ ACCOUNT STATEMENT в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
.statement-header {
  background: var(--ink);
  color: white;
  padding: 28px 32px;
  border-radius: var(--rl) var(--rl) 0 0;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.balance-hero {
  font-size: 38px;
  font-weight: 800;
  letter-spacing: -2px;
  margin-top: 6px;
}

/* в”Җв”Җ RESPONSIVE в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
@media (max-width: 768px) {
  .app-layout {
    grid-template-columns: 1fr;
  }

  .sidebar {
    display: none;
  }

  .form-row {
    grid-template-columns: 1fr;
  }

  .metrics-grid {
    grid-template-columns: 1fr 1fr;
  }
}

.msg-bot {
